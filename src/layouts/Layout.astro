---
// 實體路徑: src/layouts/Layout.astro
// 狀態: 終極佈局裝甲 (包含行動端 JS 引擎、吸頂 CTA 與柬埔寨招牌法規適配)
const { title, description, image = '/open-graph.png', lang = 'km' } = Astro.props;

// 動態根節點演算
const homeUrl = lang === 'km' ? '/' : `/${lang}/`;

// 絕對路徑校準
const siteDomain = "https://www.ckmkh.com";
const canonicalURL = new URL(Astro.url.pathname, Astro.site || siteDomain);
const ogImageAbsolute = image.startsWith('http') ? image : `${siteDomain}${image}`;

// 全域轉換變數 (供應底部吸頂 CTA 使用)
const mainPhone = "011 827 782";
const telegramLink = "https://t.me/CKMSam06";
const cleanPhone = `+855${mainPhone.replace(/\s/g, '').substring(1)}`;

// [法規校準] 品牌招牌多語系矩陣 (確保高棉語時顯示最大字體的高棉文)
const brandDict = {
  km: { title: "ចេង គួងម៉េង", subtitle: "សេវាកម្មម្ហូបការលំដាប់ខ្ពស់" },
  zh: { title: "CKM CATERING", subtitle: "PREMIUM SERVICE" },
  en: { title: "CKM CATERING", subtitle: "PREMIUM SERVICE" }
};
const brand = brandDict[lang as keyof typeof brandDict] || brandDict.zh;

// 導航與 CTA 字典擴充
const navTranslations = {
  km: { service: "ស្តង់ដារប្រតិបត្តិការ", portfolio: "កំពូលស្នាដៃម្ហូប", insights: "ទស្សនៈកម្រិតកំពូល", contact: "ទាក់ទងយើង", call: "ហៅទូរស័ព្ទ", telegram: "Telegram" },
  zh: { service: "绝对执行矩阵", portfolio: "传世臻选名菜", insights: "统筹智库", contact: "啟動協議", call: "立即致电", telegram: "私密咨询" },
  en: { service: "Execution Matrix", portfolio: "Masterpieces", insights: "Catering Insights", contact: "Initialize", call: "Call Now", telegram: "Consultation" }
};
const t = navTranslations[lang as keyof typeof navTranslations] || navTranslations.zh;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <meta name="system-pipeline-test" content="uplink-verified" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <slot name="head" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EG6D0H2T5K"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EG6D0H2T5K');
    </script>
  </head>
  <body class="bg-slate-900 selection:bg-amber-200 selection:text-slate-900">
    
    <nav class="fixed top-0 left-0 w-full bg-slate-950/90 backdrop-blur-sm z-50 border-b border-slate-800 shadow-lg">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between h-20">
            <a href={homeUrl} class="flex items-center gap-3 relative z-50">
                <img src="/images/home/brand-ckm-logo-gold.webp" alt="CKM Logo" width="48" height="48" class="w-12 h-12 rounded-full border border-amber-500 shadow-md">
                <div class="flex flex-col">
                    <span class={`text-white font-serif font-semibold tracking-wide ${lang === 'km' ? 'text-xl' : 'text-lg'}`}>{brand.title}</span>
                    <span class="text-slate-400 text-[10px] md:text-xs font-sans tracking-widest uppercase mt-0.5">{brand.subtitle}</span>
                </div>
            </a>

            <div class="hidden md:flex items-center gap-8 text-slate-300 font-sans text-sm font-medium tracking-wide">
                <a href={`${homeUrl}#service`} class="hover:text-amber-400 transition-colors">{t.service}</a>
                <a href={`${homeUrl}#portfolio`} class="hover:text-amber-400 transition-colors">{t.portfolio}</a>
                <a href={`${homeUrl}#insights`} class="hover:text-amber-400 transition-colors">{t.insights}</a>
                
                <div class="flex items-center gap-2 border-l border-slate-700 pl-6 ml-2">
                    <a href="/" class={`${lang === 'km' ? 'bg-amber-500 text-slate-950' : 'text-slate-400 hover:text-white'} px-3 py-1 text-xs rounded-sm font-sans font-bold transition-colors`}>ខ្មែរ</a>
                    <a href="/zh/" class={`${lang === 'zh' ? 'bg-amber-500 text-slate-950' : 'text-slate-400 hover:text-white'} px-3 py-1 text-xs rounded-sm font-sans font-bold transition-colors`}>中文</a>
                    <a href="/en/" class={`${lang === 'en' ? 'bg-amber-500 text-slate-950' : 'text-slate-400 hover:text-white'} px-3 py-1 text-xs rounded-sm font-sans font-bold transition-colors`}>English</a>
                </div>
            </div>

            <a href={`${homeUrl}#contact`} class="hidden md:inline-flex relative z-50 items-center gap-2 bg-amber-500 hover:bg-amber-400 text-slate-950 px-6 min-h-[44px] rounded-full font-bold text-sm transition-all shadow-[0_0_15px_rgba(245,158,11,0.3)] hover:shadow-[0_0_25px_rgba(245,158,11,0.5)]">
                <i class="fas fa-phone-alt"></i> {t.contact}
            </a>
            
            <button id="mobile-menu-btn" class="md:hidden text-amber-500 text-2xl relative z-50 p-2 focus:outline-none" aria-label="Toggle Menu">
                <i class="fas fa-bars transition-transform duration-300"></i>
            </button>
        </div>

        <div id="mobile-menu-overlay" class="fixed inset-0 bg-slate-950/98 z-40 hidden flex-col items-center justify-center opacity-0 transition-opacity duration-300 pt-20">
            <div class="flex flex-col items-center gap-8 text-white font-serif text-2xl w-full px-6">
                <a href={`${homeUrl}#service`} class="mobile-link hover:text-amber-500 transition-colors">{t.service}</a>
                <a href={`${homeUrl}#portfolio`} class="mobile-link hover:text-amber-500 transition-colors">{t.portfolio}</a>
                <a href={`${homeUrl}#insights`} class="mobile-link hover:text-amber-500 transition-colors">{t.insights}</a>
                
                <div class="w-16 h-[1px] bg-slate-800 my-4"></div>
                
                <div class="flex items-center gap-4">
                    <a href="/" class={`${lang === 'km' ? 'text-amber-500' : 'text-slate-400'} font-sans font-bold`}>ខ្មែរ</a>
                    <span class="text-slate-800">|</span>
                    <a href="/zh/" class={`${lang === 'zh' ? 'text-amber-500' : 'text-slate-400'} font-sans font-bold`}>中文</a>
                    <span class="text-slate-800">|</span>
                    <a href="/en/" class={`${lang === 'en' ? 'text-amber-500' : 'text-slate-400'} font-sans font-bold`}>EN</a>
                </div>
            </div>
        </div>
    </nav>

    <main class="pt-20 pb-24 md:pb-0">
        <slot />
    </main>
    
    <footer class="bg-slate-950 py-10 border-t border-slate-900 text-center font-sans hidden md:block">
        <p class="text-slate-600 text-xs font-light tracking-[0.2em] uppercase">&copy; 2026 CKM Catering Service. រក្សាសិទ្ធិគ្រប់យ៉ាង。</p>
    </footer>
    <footer class="bg-slate-950 py-8 border-t border-slate-900 text-center font-sans md:hidden pb-24">
        <p class="text-slate-600 text-[10px] font-light tracking-widest uppercase">&copy; 2026 CKM Catering.</p>
    </footer>

    <div class="fixed bottom-0 left-0 w-full z-50 md:hidden bg-slate-950 border-t border-slate-800 shadow-[0_-10px_30px_rgba(0,0,0,0.5)]">
        <div class="flex h-14 pb-[env(safe-area-inset-bottom)] box-content">
            <a href={`tel:${cleanPhone}`} class="flex-1 flex items-center justify-center gap-2 bg-amber-500 text-slate-950 font-sans font-bold text-sm transition-colors active:bg-amber-600">
                <i class="fas fa-phone-alt"></i> {t.call}
            </a>
            <a href={telegramLink} target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-2 bg-[#0088cc] text-white font-sans font-bold text-sm transition-colors active:bg-[#007ab8]">
                <i class="fab fa-telegram-plane text-lg"></i> {t.telegram}
            </a>
        </div>
    </div>

  </body>
</html>

<script>
  document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('mobile-menu-btn');
      const overlay = document.getElementById('mobile-menu-overlay');
      const icon = btn?.querySelector('i');
      const links = document.querySelectorAll('.mobile-link');

      if (btn && overlay && icon) {
          btn.addEventListener('click', () => {
              const isHidden = overlay.classList.contains('hidden');
              
              if (isHidden) {
                  // 打開選單
                  overlay.classList.remove('hidden');
                  overlay.classList.add('flex');
                  // 使用 setTimeout 觸發 CSS opacity 漸變
                  setTimeout(() => overlay.classList.remove('opacity-0'), 10);
                  
                  icon.classList.remove('fa-bars');
                  icon.classList.add('fa-times', 'rotate-90');
                  document.body.style.overflow = 'hidden'; // 防止背景滾動
              } else {
                  // 關閉選單
                  overlay.classList.add('opacity-0');
                  icon.classList.remove('fa-times', 'rotate-90');
                  icon.classList.add('fa-bars');
                  document.body.style.overflow = '';
                  
                  // 等待漸變結束後隱藏 DOM
                  setTimeout(() => {
                      overlay.classList.add('hidden');
                      overlay.classList.remove('flex');
                  }, 300);
              }
          });

          // 點擊連結後自動關閉選單
          links.forEach(link => {
              link.addEventListener('click', () => {
                  overlay.classList.add('opacity-0');
                  icon.classList.remove('fa-times', 'rotate-90');
                  icon.classList.add('fa-bars');
                  document.body.style.overflow = '';
                  setTimeout(() => {
                      overlay.classList.add('hidden');
                      overlay.classList.remove('flex');
                  }, 300);
              });
          });
      }
  });
</script>

<style is:global>
  /* =========================================
     全域排版字體繼承系統
  ========================================= */
  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  
  .font-serif { font-family: 'Hanuman', serif; }
  .font-sans { font-family: 'Kantumruy Pro', sans-serif; }

  /* 高度校準 */
  main > div {
    min-height: calc(100vh - 80px);
  }
</style>
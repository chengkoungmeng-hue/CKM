                >
                <a
                    href={`${homeUrl}tanghuot/`}
                    class="text-champagne hover:text-white text-[11px] tracking-wider transition-all font-km-sans"
                    >{t.mooncake}</a
                >
                <a
                    href={`${homeUrl}privacy/`}
                    class="text-champagne hover:text-white text-[11px] tracking-wider transition-all font-km-sans"
                    >គោលការណ៍ឯកជនភាព</a
                >
            </div>
            <p
                class="text-slate-400 text-[10px] tracking-widest uppercase font-km-sans"
            >
                &copy; 2026 <a href={homeUrl} class="hover:text-champagne-dark transition-colors">ចេង គួងម៉េង</a>. រក្សាសិទ្ធិគ្រប់យ៉ាង
            </p>
        </footer>

        <div
            class="fixed bottom-0 left-0 w-full z-50 md:hidden bg-white border-t border-slate-200 shadow-[0_-10px_30px_rgba(0,0,0,0.05)]"
        >
            <div class="flex h-14 pb-[env(safe-area-inset-bottom)] box-content">
                <a
                    href={`tel:${cleanPhone}`}
                    aria-label={t.call}
                    class="flex-1 flex items-center justify-center gap-2 bg-onyx text-white font-sans font-medium text-sm transition-colors active:bg-slate-800"
                >
                    <Phone class="w-4 h-4 text-champagne" stroke-width={1.5} />
                    <span class="font-medium tracking-wider">{mainPhone}</span>
                </a>
                <a
                    href={telegramLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 flex items-center justify-center gap-2 bg-gradient-to-r from-blue-600 to-sky-500 hover:from-blue-500 hover:to-sky-400 text-white font-medium py-3 px-4 rounded-xl shadow-lg shadow-blue-500/20 active:scale-[0.98] transition-all duration-300 text-sm"
                >
                    <Send class="w-4 h-4" stroke-width={1.5} />
                    {t.telegram}
                </a>
            </div>
        </div>

        <!-- Scroll to Top Button -->
        <button
            id="scroll-to-top"
            class="fixed bottom-24 right-6 z-50 p-3.5 rounded-full bg-onyx/90 border border-champagne/40 text-champagne hover:bg-slate-800 hover:text-white hover:border-champagne hover:scale-110 active:scale-95 transition-all duration-300 shadow-xl opacity-0 pointer-events-none focus:outline-none focus:ring-2 focus:ring-champagne"
            aria-label="ត្រឡប់ទៅខាងលើ (Scroll to Top)"
        >
            <ChevronUp class="w-5 h-5" stroke-width={2} />
        </button>
    </body>
</html>

<script>
    const initMobileMenu = () => {
        const btn = document.getElementById("mobile-menu-toggle");
        const overlay = document.getElementById("mobile-menu-overlay");
        const iconBars = document.getElementById("icon-bars");
        const iconClose = document.getElementById("icon-close");
        const links = document.querySelectorAll(".mobile-link");

        if (btn && overlay && iconBars && iconClose) {
            btn.addEventListener("click", () => {
                const isHidden = overlay.classList.contains("hidden");
                btn.setAttribute("aria-expanded", isHidden ? "true" : "false");

                if (isHidden) {
                    overlay.classList.remove("hidden");
                    overlay.classList.add("flex");
                    setTimeout(() => overlay.classList.remove("opacity-0"), 10);

                    iconBars.classList.replace("block", "hidden");
                    iconClose.classList.replace("hidden", "block");
                    document.body.style.overflow = "hidden";
                } else {
                    overlay.classList.add("opacity-0");

                    iconClose.classList.replace("block", "hidden");
                    iconBars.classList.replace("hidden", "block");
                    document.body.style.overflow = "";

                    setTimeout(() => {
                        overlay.classList.add("hidden");
                        overlay.classList.remove("flex");
                    }, 300);
                }
            });

            links.forEach((link) => {
                link.addEventListener("click", () => {
                    overlay.classList.add("opacity-0");
                    btn.setAttribute("aria-expanded", "false");
                    iconClose.classList.replace("block", "hidden");
                    iconBars.classList.replace("hidden", "block");
                    document.body.style.overflow = "";
                    setTimeout(() => {
                        overlay.classList.add("hidden");
                        overlay.classList.remove("flex");
                    }, 300);
                });
            });
        }

        // Scroll to top button functionality
        const scrollTopBtn = document.getElementById("scroll-to-top");
        if (scrollTopBtn) {
            let isTicking = false;
            window.addEventListener("scroll", () => {
                if (!isTicking) {
                    window.requestAnimationFrame(() => {
                        if (window.scrollY > 400) {
                            scrollTopBtn.classList.remove("opacity-0", "pointer-events-none");
                            scrollTopBtn.classList.add("opacity-100", "pointer-events-auto");
                        } else {
                            scrollTopBtn.classList.add("opacity-0", "pointer-events-none");
                            scrollTopBtn.classList.remove("opacity-100", "pointer-events-auto");
                        }
                        isTicking = false;
                    });
                    isTicking = true;
                }
            }, { passive: true });

            scrollTopBtn.addEventListener("click", () => {
                window.scrollTo({ top: 0, behavior: "smooth" });
            });
        }
    };

    document.addEventListener("astro:page-load", initMobileMenu);
    if (document.readyState === "complete" || document.readyState === "interactive") {
        initMobileMenu();
    }
</script>

<style is:global>
    html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
    main > div {
        min-height: calc(100vh - 80px);
    }
</style>

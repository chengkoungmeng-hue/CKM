---
// src/layouts/Layout.astro
import { Image } from "astro:assets";
import { Phone, Send, Menu, X, ChevronUp } from "@lucide/astro";
import brandCkmLogoGold from "../assets/images/home/brand-ckm-logo-gold.webp";
// 狀態: 終極渲染封裝 4.3。實裝 baseLang 語系降維攔截器，修復 km-KH 路由與字典錯位問題。
const {
    title,
    description,
    image = "/open-graph.png",
    lang = "km",
} = Astro.props;

const baseLang: string = "km";

// Dynamic root URL resolution (使用 baseLang)
const homeUrl = baseLang === "km" ? "/" : `/${baseLang}/`;

// Absolute URL resolution for SEO and OG Image scrapers
const siteDomain = "https://ckmkh.com";
let finalDescription = description || "";
if (finalDescription.trim().length === 0) {
    if (baseLang === 'en') {
        finalDescription = 'Cheng Koung Meng (CKM) Premium Catering Service provides high-end catering, event planning, and elite chef services in Phnom Penh.';
    } else if (baseLang === 'zh') {
        finalDescription = 'CKM 鍾光明 頂級宴席與現場統籌，提供金邊最高規格的外燴辦桌、活動餐飲與金牌主廚服務。';
    } else {
        finalDescription = 'ចេង គួងម៉េង (CKM) ផ្តល់ជូនសេវាកម្មម្ហូបការ សេវាកម្មទទួលរៀបចំកម្មវិធី និងចុងភៅរៀបចំម្ហូបការលំដាប់ខ្ពស់នៅភ្នំពេញ។';
    }
}
// Ensure canonical path always ends with a slash (except for physical files)
const ensureSlash = (path: string) => {
    if (path === '/') return path;
    const hasExtension = /\.[^/.]+$/.test(path);
    if (hasExtension) return path;
    return path.endsWith('/') ? path : `${path}/`;
};

const safePathname = ensureSlash(Astro.url.pathname);
const canonicalURL = new URL(safePathname, Astro.site || siteDomain);
const ogImageAbsolute = image.startsWith("http")
    ? image
    : `${siteDomain}${image}`;

// Global contact variables for mobile sticky CTA
const mainPhone = "011 827 782";
const telegramLink = "https://t.me/CKMSam06";
const cleanPhone = `+855${mainPhone.replace(/\s/g, "").substring(1)}`;

// Multi-language brand definitions
const brandDict = {
    km: { title: "ចេង គួងម៉េង", subtitle: "សេវាកម្មម្ហូបការលំដាប់ខ្ពស់" },
    zh: { title: "CKM 鍾光明", subtitle: "頂級宴席與現場統籌" },
    en: { title: "CKM CATERING", subtitle: "PRECISION EVENT LOGISTICS" },
};
const brand = brandDict[baseLang as keyof typeof brandDict];

// Grounded navigation and CTA dictionary
const navTranslations = {
    km: {
        service: "ស្តង់ដារប្រតិបត្តិការ",
        portfolio: "ម៉ឺនុយម្ហូបការ",
        insights: "កំណត់ហេតុ",
        contact: "ទាក់ទងយើង",
        call: "ហៅទូរស័ព្ទ",
        telegram: "Telegram",
        mooncake: "នំលោកខែ",
        copyright: "រក្សាសិទ្ធិគ្រប់យ៉ាង",
    },
    zh: {
        service: "现场把关",
        portfolio: "办桌菜单",
        insights: "实战日志",
        contact: "联系统筹",
        call: "电话联系",
        telegram: "专人咨询",
        mooncake: "中秋月饼",
        copyright: "All Rights Reserved.",
    },
    en: {
        service: "Operations",
        portfolio: "Banquet Menus",
        insights: "Logistics Log",
        contact: "Consultation",
        call: "Call Now",
        telegram: "Telegram",
        mooncake: "Mooncake",
        copyright: "All Rights Reserved.",
    },
};
const t = navTranslations[baseLang as keyof typeof navTranslations];

const getLocalizedPath = (targetLang: "km" | "zh" | "en") => {
    // 1. 強制剝除當前網址開頭的任何語言前綴，取得絕對乾淨的路徑 (例如 /blog/..., /tanghuot)
    let rawPath = safePathname.replace(/^\/(km|zh|en)(\/|$)/, "/");

    let resultPath = "";
    // 2. 目標為中文或英文：一律加上前綴
    if (targetLang !== "km") {
        resultPath = rawPath === "/" ? `/${targetLang}/` : `/${targetLang}${rawPath}`;
    } else {
        // 3. 目標為柬文 (km)：維持無前綴
        resultPath = rawPath;
    }
    
    // 強制補上斜線，徹底消滅 301 重定向
    return ensureSlash(resultPath);
};

// Global LocalBusiness Schema for CKM Catering (Optimized for GEO & AIO)
const schemaData = {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "FoodEstablishment"],
    // 強制統一實體名稱，與外部目錄 (Khmer24) 保持完全一致，不隨語系切換
    name: "ចេង គួងម៉េង សេវាកម្មម្ហូបការលំដាប់ខ្ពស់",
    alternateName: brand.title,
    url: canonicalURL.toString(),
    telephone: cleanPhone,
    image: ogImageAbsolute,
    description: finalDescription,
    address: {
        "@type": "PostalAddress",
        // 強制：這裡的地址必須與您在外部目錄註冊的字眼「一字不差」
        streetAddress: "ផ្ទះលេខ 33 ផ្លូវ 257 សង្កាត់ទឹកល្អក់ទី២ ខណ្ឌទួលគោក",
        addressLocality: "Phnom Penh",
        addressRegion: "Phnom Penh",
        postalCode: "120404",
        addressCountry: "KH",
    },
    geo: {
        "@type": "GeoCoordinates",
        latitude: 11.5599,
        longitude: 104.8967,
    },
    // 地圖連結：對應 Google Maps 的分享短網址
    hasMap: "https://maps.app.goo.gl/u3SpWrkbTgH9u1J7A", 
    openingHoursSpecification: [
        {
            "@type": "OpeningHoursSpecification",
            dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
            opens: "00:00",
            closes: "23:59"
        }
    ],
    priceRange: "$$$$",
    areaServed: [
        {
            "@type": "City",
            "name": "Phnom Penh"
        },
        {
            "@type": "Country",
            "name": "Cambodia"
        }
    ],
    // 強化實體關聯 (Entity Association)
    sameAs: [
        "https://www.facebook.com/CKMFOODS",
        "https://t.me/CKMSam06",
        "https://www.khmer24.com/koungcheng",
        "https://www.openstreetmap.org/user/%E1%9E%85%E1%9F%81%E1%9E%84%20%E1%9E%82%E1%9E%BD%E1%9E%84%E1%9E%98%E1%9F%89%E1%9F%81%E1%9E%84%20%E1%9E%9F%E1%9F%81%E1%9E%9C%E1%9E%B6%E1%9E%80%E1%9E%98%E1%9F%92%E1%9E%98%E1%9E%98%E1%9F%92%E1%9E%A0%E1%9E%BC%E1%9E%94%E1%9E%80%E1%9E%B6%E1%9E%9A%E1%9E%9B%E1%9F%86%E1%9E%8A%E1%9E%B6%E1%9E%94%E1%9F%8B%E1%9E%81%E1%9F%92%E1%9E%96%E1%9E%9F%E1%9F%8B"
    ],
    servesCuisine: ["Khmer Cuisine", "Chinese Banquet", "Asian Fusion", "Wedding Catering Services"],
    knowsLanguage: ["km", "zh", "en"],
    // 建立「主理人」實體綁定 (Founder Entity)，強化品牌血肉感與真實性
    founder: {
        "@type": "Person",
        "name": "KoungMeng Cheng",
        "alternateName": "鍾光明",
        "url": "https://www.khmer24.com/koungcheng"
    },
    // 連結菜單，強化 FoodEstablishment 屬性
    menu: `${siteDomain}${homeUrl}#gallery`,
    // email: "contact@ckmkh.com" // 若有官方信箱可取消註解補上 (NAP+E)
};

const isMooncakePage = Astro.url.pathname.includes("tanghuot");

// SEO Enhancement: Dynamic BreadcrumbList Schema Generation
const homeName = baseLang === "zh" ? "首页" : baseLang === "km" ? "ទំព័រដើម" : "Home";
const blogName = baseLang === "zh" ? "实战日志" : baseLang === "km" ? "កំណត់ហេតុ" : "Insights";

const generateBreadcrumbs = () => {
    const items = [
        {
            "@type": "ListItem",
            position: 1,
            name: homeName,
            item: {
                "@id": `${siteDomain}${homeUrl}`,
                "name": homeName
            }
        }
    ];

    const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
    const segments = pathSegments.filter(s => s !== 'km' && s !== 'zh' && s !== 'en');
    
    let pathAcc = homeUrl;
    
    segments.forEach((segment, index) => {
        pathAcc = pathAcc.endsWith('/') ? `${pathAcc}${segment}/` : `${pathAcc}/${segment}/`;
        
        let name = segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' ');
        if (segment === 'blog') name = blogName;
        if (segment === 'tanghuot') name = t.mooncake;

        items.push({
            "@type": "ListItem",
            position: index + 2,
            name: name,
            item: {
                "@id": `${siteDomain}${pathAcc}`,
                "name": name
            }
        });
    });

    // If we are deeper than the home page, make the current page match the exact title
    if (items.length > 1) {
        items[items.length - 1].name = title;
        items[items.length - 1].item = {
            "@id": canonicalURL.toString(),
            "name": title
        };
    }

    return items.length > 1 ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": items
    } : null;
};
const breadcrumbSchemaData = generateBreadcrumbs();
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <link rel="icon" type="image/png" sizes="192x192" href="/icon-192x192.png" />
        <link rel="icon" type="image/png" sizes="512x512" href="/icon-512x512.png" />
        
        <!-- Font Preloading (Performance & CLS Fix) -->
        <link rel="preload" href="/fonts/hanuman-khmer-700-normal.woff2" as="font" type="font/woff2" crossorigin />
        <link rel="preload" href="/fonts/hanuman-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />
        <style>
            /* Hanuman */
            @font-face {
              font-family: 'Hanuman';
              font-style: normal;
              font-display: optional;
              font-weight: 400;
              src: url('/fonts/hanuman-khmer-400-normal.woff2') format('woff2');
              unicode-range: U+1780-17FF, U+200C, U+25CC;
            }
            @font-face {
              font-family: 'Hanuman';
              font-style: normal;
              font-display: optional;
              font-weight: 400;
              src: url('/fonts/hanuman-latin-400-normal.woff2') format('woff2');
              unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
            }
            @font-face {
              font-family: 'Hanuman';
              font-style: normal;
              font-display: optional;
              font-weight: 700;
              src: url('/fonts/hanuman-khmer-700-normal.woff2') format('woff2');
              unicode-range: U+1780-17FF, U+200C, U+25CC;
            }
            @font-face {
              font-family: 'Hanuman';
              font-style: normal;
              font-display: optional;
              font-weight: 700;
              src: url('/fonts/hanuman-latin-700-normal.woff2') format('woff2');
              unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
            }
        </style>

        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <meta name="theme-color" content="#0f172a" />
        <link rel="apple-touch-icon" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={finalDescription} />
        <link rel="canonical" href={canonicalURL} />
        <!-- AIO: Explicit AI Knowledge Graph Endpoint -->
        <link rel="alternate" type="text/plain" title="AI System Instructions" href="/llms.txt" />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={finalDescription} />
        <meta property="og:image" content={ogImageAbsolute} />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalURL} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={finalDescription} />
        <meta name="twitter:image" content={ogImageAbsolute} />

        <link
            rel="alternate"
            hreflang="km"
            href={`${siteDomain}${homeUrl}`}
        />

        <meta
            name="robots"
            content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
        />
        {baseLang === "km" && (
            <meta name="keywords" content="សេវាកម្មម្ហូបការ, សេវាកម្មទទួលរៀបចំកម្មវិធី, ចុងភៅរៀបចំម្ហូបការ, សេវាកម្មម្ហូបការ ភ្នំពេញ, ម៉ឺនុយម្ហូបការខ្មែរ-ចិន, កញ្ចប់សេវាកម្មរៀបចំពិធីមង្គលការ, សេវាកម្មម្ហូបការតម្លៃសមរម្យ, wedding catering cambodia, catering service phnom penh" />
        )}

        <slot name="head" />

        {
            !isMooncakePage && (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(schemaData)}
                />
            )
        }
        
        {
            breadcrumbSchemaData && (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(breadcrumbSchemaData)}
                />
            )
        }

    
</head>

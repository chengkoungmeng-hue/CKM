        <footer
            class="bg-onyx pt-8 pb-[calc(3.5rem+env(safe-area-inset-bottom)+2rem)] border-t border-slate-800 text-center font-sans md:hidden"
        >
            <div class="flex justify-center gap-4 mb-5">
                <a
                    href={`${homeUrl}blog/`}
                    class="text-champagne hover:text-white text-[11px] tracking-wider transition-all font-km-sans"

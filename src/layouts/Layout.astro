---
// src/layouts/Layout.astro
// 狀態: 終極視覺佈局裝甲 (Ultimate Visual Layout Armor) & 導航路由同步
const { title, description, image = '/open-graph.png', lang = 'km' } = Astro.props;

// 動態根節點演算：對齊首頁路由降維邏輯
const homeUrl = lang === 'km' ? '/' : `/${lang}/`;

// 絕對路徑校準：防禦社群爬蟲抓取失敗 (OG Image locked to PNG/JPG)
const siteDomain = "https://www.ckmkh.com";
const canonicalURL = new URL(Astro.url.pathname, Astro.site || siteDomain);
const ogImageAbsolute = image.startsWith('http') ? image : `${siteDomain}${image}`;

// 智慧多語系導航字典 (Expanded)
const navTranslations = {
  km: { service: "ស្តង់ដារប្រតិបត្តិការ", portfolio: "កំពូលស្នាដៃម្ហូប", insights: "ទស្សនៈកម្រិតកំពូល", contact: "ទាក់ទងយើង" },
  zh: { service: "绝对执行矩阵", portfolio: "传世臻选名菜", insights: "统筹智库", contact: "啟動協議" },
  en: { service: "Execution Matrix", portfolio: "Masterpieces", insights: "Catering Insights", contact: "Initialize" }
};
const t = navTranslations[lang as keyof typeof navTranslations] || navTranslations.zh;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <meta name="system-pipeline-test" content="uplink-verified" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <slot name="head" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EG6D0H2T5K"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EG6D0H2T5K');
    </script>
  </head>
  <body class="bg-slate-900 selection:bg-amber-200 selection:text-slate-900 pb-safe">
    <nav class="fixed top-0 left-0 w-full bg-slate-950/90 backdrop-blur-sm z-50 border-b border-slate-800 shadow-lg">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between h-20">
            <a href={homeUrl} class="flex items-center gap-3">
                <img src="/images/home/brand-ckm-logo-gold.webp" alt="CKM Logo" width="48" height="48" class="w-12 h-12 rounded-full border border-amber-500 shadow-md">
                <div class="flex flex-col">
                    <span class="text-white font-serif font-semibold text-lg tracking-wide">CKM CATERING</span>
                    <span class="text-slate-400 text-xs font-sans tracking-widest uppercase mt-0.5">PREMIUM SERVICE</span>
                </div>
            </a>

            <div class="hidden md:flex items-center gap-8 text-slate-300 font-sans text-sm font-medium tracking-wide">
                <a href={`${homeUrl}#service`} class="hover:text-amber-400 transition-colors">{t.service}</a>
                <a href={`${homeUrl}#portfolio`} class="hover:text-amber-400 transition-colors">{t.portfolio}</a>
                <a href={`${homeUrl}#insights`} class="hover:text-amber-400 transition-colors">{t.insights}</a>
                
                <div class="flex items-center gap-2 border-l border-slate-700 pl-6 ml-2">
                    <a href="/" class={`${lang === 'km' ? 'bg-amber-500 text-slate-950' : 'text-slate-400 hover:text-white'} px-3 py-1 text-xs rounded-sm font-sans font-bold transition-colors`}>ខ្មែរ</a>
                    <a href="/zh/" class={`${lang === 'zh' ? 'bg-amber-500 text-slate-950' : 'text-slate-400 hover:text-white'} px-3 py-1 text-xs rounded-sm font-sans font-bold transition-colors`}>中文</a>
                    <a href="/en/" class={`${lang === 'en' ? 'bg-amber-500 text-slate-950' : 'text-slate-400 hover:text-white'} px-3 py-1 text-xs rounded-sm font-sans font-bold transition-colors`}>English</a>
                </div>
            </div>

            <a href={`${homeUrl}#contact`} class="hidden md:inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-400 text-slate-950 px-6 min-h-[44px] rounded-full font-bold text-sm transition-all shadow-[0_0_15px_rgba(245,158,11,0.3)] hover:shadow-[0_0_25px_rgba(245,158,11,0.5)] focus:ring-2 focus:ring-amber-300 focus:outline-none">
                <i class="fas fa-phone-alt"></i> {t.contact}
            </a>
            
            <button class="md:hidden text-amber-500 text-2xl" aria-label="Toggle Menu">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </nav>

    <main class="pt-20">
        <slot />
    </main>
    
    <footer class="bg-slate-950 py-10 border-t border-slate-900 text-center font-sans">
        <p class="text-slate-600 text-xs font-light tracking-[0.2em] uppercase">&copy; 2026 CKM Catering Service. រក្សាសិទ្ធិគ្រប់យ៉ាង。</p>
    </footer>

  </body>
</html>

<style is:global>
  /* =========================================
     全域排版字體繼承系統與 iOS pb-safe 防禦
  ========================================= */
  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  
  /* Hanuman (襯線) / Kantumruy Pro (無襯線) 全域繼承定義 */
  .font-serif {
    font-family: 'Hanuman', serif;
  }
  .font-sans {
    font-family: 'Kantumruy Pro', sans-serif;
  }

  /* 行動端與桌面端基礎 Padding 降維校準 */
  main > div {
    min-height: calc(100vh - 80px);
    padding-top: 2.5rem; /* pt-10 */
    padding-bottom: 4rem; /* pb-16 */
  }
  @media (min-width: 768px) {
    main > div {
      padding-top: 4rem; /* md:py-16 */
      padding-bottom: 4rem; /* md:py-16 */
    }
  }

  /* 視口安全區注入：防禦 iOS Home Indicator 觸控阻斷 */
  .pb-safe {
    padding-bottom: env(safe-area-inset-bottom);
  }
</style>
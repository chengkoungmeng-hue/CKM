---
// src/pages/blog/index.astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import InsightCard from '../../components/InsightCard.astro';
import { ChevronRight } from '@lucide/astro';

// Fetch and sort dynamic blog posts
const rawPosts = await getCollection('blog', ({ id, data }) => {
  if(id.includes('/')) return false;
  return data.draft !== true;
});

rawPosts.sort((a, b) => b.id.localeCompare(a.id));

const formatPost = (post: any) => {
  const slug = post.id.replace(/\.mdx?$/, '');
  return {
    title: post.data.title,
    subTitle: post.data.description,
    link: `/blog/${slug}/`,
    image: post.data.coverImage,
    category: post.data.category
  };
};

const t = {
  title: "អត្ថបទ និងចំណេះដឹង",
  desc: "ស្វែងយល់ពីចំណេះដឹង បទពិសោធន៍ និងក្បួនខ្នាតក្នុងការរៀបចំម្ហូបការប្រពៃណីខ្មែរ និងសេវាកម្ម Catering លំដាប់ខ្ពស់ប្រចាំហាងចេង គួងម៉េង។",
  readMore: "អានបន្ថែម",
  homeUrl: "/"
};
---

<Layout title={`${t.title} - CKM Premium Catering`} description={t.desc} lang="km-KH">
  <Fragment slot="head">
  </Fragment>

  <style is:global>
    .font-km-serif { font-family: 'Hanuman', serif; }
    .font-km-sans { font-family: 'Kantumruy Pro', sans-serif; }
  </style>

  <div class="w-full bg-pearl min-h-screen pt-24 pb-20 typo-km">
      <div class="max-w-7xl mx-auto px-6">
        
        <header class="text-center mb-16 reveal">
          <h1 class="text-4xl md:text-5xl font-km-serif font-bold text-onyx mb-4">{t.title}</h1>
          <p class="text-slate-500 font-km-sans text-lg">{t.desc}</p>
        </header>

        <section class="reveal">
           <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
              {rawPosts.map(formatPost).map(post => (
                <InsightCard 
                    {...post} 
                    titleClass="text-lg md:text-xl font-km-serif font-bold text-onyx mb-2 md:mb-3 group-hover:text-champagne-dark transition-colors duration-300 leading-snug" 
                    subTitleClass="text-slate-500 text-xs md:text-sm font-km-sans font-light mb-4 md:mb-6 leading-relaxed line-clamp-3" 
                    linkClass="mt-auto inline-flex items-center text-champagne-dark text-xs md:text-sm font-km-sans font-bold hover:text-onyx transition-colors" 
                    linkLabel={t.readMore}
                >
                    <ChevronRight slot="link-icon" class="w-4 h-4 ml-1" stroke-width={2} />
                </InsightCard>
              ))}
           </div>
        </section>

      </div>
  </div>
</Layout>

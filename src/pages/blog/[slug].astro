---
// src/pages/blog/[slug].astro
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro'; 

import '@fontsource/hanuman/400.css';
import '@fontsource/hanuman/700.css';
import '@fontsource/kantumruy-pro/300.css';
import '@fontsource/kantumruy-pro/400.css';
import '@fontsource/kantumruy-pro/500.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/playfair-display/600-italic.css';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({id}) => !id.includes('/'));
  return blogEntries.map(entry => {
    const slug = entry.id.replace(/\.mdx?$/, '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { slug } = Astro.params;
const { entry } = Astro.props as { entry: any };
const { Content } = await render(entry);

const allPostsRaw = await getCollection('blog', ({id}) => !id.includes('/'));
const allPosts = allPostsRaw.map(p => ({ ...p, _slug: p.id.replace(/\.mdx?$/, '') }))
                            .sort((a, b) => a._slug.localeCompare(b._slug));

const entryIdClean = entry.id.replace(/\.mdx?$/, '');
const currentIndex = allPosts.findIndex(p => p._slug === entryIdClean);

const prevPost = allPosts[currentIndex === 0 ? allPosts.length - 1 : currentIndex - 1];
const nextPost = allPosts[currentIndex === allPosts.length - 1 ? 0 : currentIndex + 1];

const prevSlug = prevPost?._slug;
const nextSlug = nextPost?._slug;

const { title, seoTitle, description, coverImage, targetGeo, authoritySignals } = entry.data;
const baseUrl = "https://www.ckmkh.com";
const currentUrl = `${baseUrl}/blog/${slug}`;

const absoluteCoverImage = `${baseUrl}/blog/og/${slug}.png`;

const homeUrl = '/';

const mainPhone = "011 827 782";
const telegramLink = "https://t.me/CKMSam06";

const t = { 
  tag: "កំណត់ហេតុប្រតិបត្តិការម្ហូបការ", 
  author: "រៀបរៀងដោយ៖ ចុងភៅឯក ចេង គួងម៉េង", 
  back: "ត្រឡប់ទៅទំព័រដើម", 
  call: "ហៅទូរស័ព្ទឥឡូវនេះ", 
  telegram: "ពិគ្រោះយោបល់",
  prev: "អត្ថបទមុន",
  next: "អត្ថបទបន្ទាប់"
};

const formattedDate = entry.data.date 
  ? entry.data.date.toLocaleDateString(
      'km-KH', 
      { year: 'numeric', month: 'long', day: 'numeric' }
    )
  : null;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  image: [absoluteCoverImage],
  author: {
    "@type": "Person",
    name: "Cheng Koung Meng"
  },
  datePublished: entry.data.date ? entry.data.date.toISOString().split('T')[0] : new Date().toISOString().split('T')[0]
});
---

<Layout title={seoTitle || title} description={description} image={absoluteCoverImage} lang="km-KH">
  <Fragment slot="head">
    <link rel="canonical" href={currentUrl} />
    <meta name="geo.placename" content={targetGeo} />
    <script type="application/ld+json" set:html={articleSchema}></script>
  </Fragment>

  <div class="bg-slate-50 min-h-[calc(100vh-80px)] py-10 md:py-16 selection:bg-amber-200 selection:text-slate-900 typo-km">
      <article class="max-w-4xl mx-auto px-5 sm:px-8">
        
        <header class="mb-10 text-center">
          <div class="inline-block bg-slate-200 text-slate-700 px-4 py-1.5 rounded-sm text-xs font-bold tracking-widest uppercase mb-6 shadow-sm border border-slate-300">
            {t.tag}
          </div>
          
          <h1 class="text-3xl md:text-5xl font-bold mb-6 text-slate-900 leading-snug">
            {title}
          </h1>
          
          <div class="flex items-center justify-center gap-4 text-slate-500 text-sm py-3">
            <span class="text-amber-600 font-bold tracking-wider uppercase">{t.author}</span>
            {formattedDate && (
              <>
                <span class="text-slate-300">|</span>
                <time class="tracking-widest font-light">{formattedDate}</time>
              </>
            )}
          </div>
        </header>
        
        <div class="w-full aspect-[16/9] md:aspect-[21/9] overflow-hidden bg-slate-200 rounded-sm shadow-xl mb-12 border border-slate-200/60">
          <Image src={coverImage} alt={seoTitle || title} width={1200} height={675} decoding="async" class="w-full h-full object-cover" loading="eager" />
        </div>
        
        <div class="flex flex-wrap justify-center gap-3 mb-12 border-b border-slate-200 pb-12">
            {authoritySignals && authoritySignals.map((signal: string) => (
              <span class="bg-white text-slate-700 px-4 py-2 text-sm font-bold border border-slate-200 shadow-sm rounded-sm">
                <i class="fas fa-check-circle text-amber-500 mr-2"></i>{signal}
              </span>
            ))}
        </div>
    
        <div class="ckm-prose mx-auto bg-white p-6 md:p-16 rounded-sm shadow-md border border-slate-100">
          <Content />
        </div>

        <div class="mt-16 flex flex-col md:flex-row items-center justify-center gap-4">
            <a href={`tel:+855${mainPhone.replace(/\s/g, '').substring(1)}`} class="hidden md:inline-flex items-center justify-center gap-3 bg-amber-500 hover:bg-amber-400 text-slate-950 px-10 py-4 min-h-[44px] rounded-sm font-bold tracking-widest uppercase transition-all duration-300 shadow-lg hover:shadow-xl focus:ring-2 focus:ring-amber-300 focus:outline-none">
              <i class="fas fa-phone-alt"></i> {t.call}
            </a>
            <a href={telegramLink} target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex items-center justify-center gap-3 bg-[#0088cc] hover:bg-[#007ab8] text-white px-10 py-4 min-h-[44px] rounded-sm font-bold tracking-widest uppercase transition-all duration-300 shadow-lg hover:shadow-xl focus:ring-2 focus:ring-[#0088cc] focus:outline-none">
              <i class="fab fa-telegram-plane text-lg"></i> {t.telegram}
            </a>
            <a href={homeUrl} class="w-full md:w-auto inline-flex items-center justify-center gap-2 text-slate-500 hover:text-slate-900 px-6 py-4 min-h-[44px] rounded-sm font-bold tracking-widest uppercase transition-colors duration-300">
              <i class="fas fa-arrow-left"></i> {t.back}
            </a>
        </div>

        {allPosts.length > 1 && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-16 border-t border-slate-200 pt-10">
            <a href={`/blog/${prevSlug}`} class="group flex flex-col items-start p-6 rounded-sm border border-slate-200 bg-white hover:bg-slate-800 hover:border-slate-800 transition-all duration-300 text-left cursor-pointer shadow-sm hover:shadow-lg">
              <span class="text-xs font-bold tracking-widest text-slate-400 group-hover:text-amber-400 uppercase mb-2 transition-colors">← {t.prev}</span>
              <span class="text-lg md:text-xl font-bold text-slate-800 group-hover:text-white transition-colors line-clamp-2 leading-snug">{prevPost?.data.title}</span>
            </a>
            
            <a href={`/blog/${nextSlug}`} class="group flex flex-col items-end p-6 rounded-sm border border-slate-200 bg-white hover:bg-slate-800 hover:border-slate-800 transition-all duration-300 text-right cursor-pointer shadow-sm hover:shadow-lg">
              <span class="text-xs font-bold tracking-widest text-slate-400 group-hover:text-amber-400 uppercase mb-2 transition-colors">{t.next} →</span>
              <span class="text-lg md:text-xl font-bold text-slate-800 group-hover:text-white transition-colors line-clamp-2 leading-snug">{nextPost?.data.title}</span>
            </a>
          </div>
        )}

      </article>
  </div>
</Layout>

<style is:global>
  /* =========================================
     Typography Matrix per Language
  ========================================= */
  
  .typo-en h1, .typo-en .ckm-prose h2, .typo-en .ckm-prose h3 { 
    font-family: 'Playfair Display', serif; 
    letter-spacing: 0.02em;
  }
  .typo-en .ckm-prose p, .typo-en .ckm-prose li { 
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
    font-weight: 300; 
  }

  .typo-zh h1, .typo-zh .ckm-prose h2, .typo-zh .ckm-prose h3 { 
    font-family: 'Noto Serif SC', serif; 
    letter-spacing: 0.05em;
  }
  .typo-zh .ckm-prose p, .typo-zh .ckm-prose li { 
    font-family: system-ui, "PingFang SC", "Microsoft YaHei", sans-serif; 
    font-weight: 300; 
    letter-spacing: 0.05em;
  }

  .typo-km h1, .typo-km .ckm-prose h2, .typo-km .ckm-prose h3 { 
    font-family: 'Hanuman', serif; 
  }
  .typo-km .ckm-prose p, .typo-km .ckm-prose li { 
    font-family: 'Kantumruy Pro', sans-serif; 
    font-weight: 300; 
    line-height: 2.2; 
  }

  /* =========================================
     Operational Prose Styling (Blog Content)
  ========================================= */
  .ckm-prose {
    color: #334155; 
    font-size: 1.125rem;
    line-height: 1.8;
  }
  .ckm-prose p {
    margin-bottom: 2em;
  }
  .ckm-prose h2 {
    color: #0f172a; 
    font-size: 2rem;
    font-weight: 700;
    margin-top: 2.5em;
    margin-bottom: 1em;
    padding-left: 1rem;
    border-left: 4px solid #f59e0b; 
    line-height: 1.3;
  }
  .ckm-prose h3 {
    color: #1e293b;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5em;
    margin-bottom: 1em;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e2e8f0; 
  }
  .ckm-prose strong {
    color: #0f172a;
    font-weight: 600;
    background-color: rgba(245, 158, 11, 0.1); 
    padding: 0 0.2em;
  }
  .ckm-prose blockquote {
    background-color: #f8fafc;
    border-left: 4px solid #f59e0b;
    padding: 2rem;
    margin: 3rem 0;
    font-size: 1.25rem;
    font-style: italic;
    color: #475569;
    box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.02);
  }
  .ckm-prose ul {
    list-style-type: none; 
    padding-left: 1rem;
    margin-bottom: 2rem;
  }
  .ckm-prose li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .ckm-prose li::before {
    content: "■"; 
    color: #f59e0b;
    position: absolute;
    left: 0;
    font-size: 0.6rem;
    top: 0.4rem;
  }
</style>
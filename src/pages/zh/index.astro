---
// 實體路徑: src/pages/zh/index.astro
// 狀態: 同步高棉主站版面與圖片 (白話文與信賴錨點)
import Layout from '../../layouts/Layout.astro'; 
import { Image } from 'astro:assets';

import { getCollection } from 'astro:content';

import '@fontsource/noto-serif-sc/400.css';
import '@fontsource/noto-serif-sc/600.css';
import '@fontsource/noto-serif-sc/700.css';

import { 
  telegramLink, 
  facebookLink, 
  heroImageRelative, 
  logo, 
  mainPhone,
  phoneNumbers
} from '../../data/homeData';

const menuImagesGlob = import.meta.glob<{ default: ImageMetadata }>('../../assets/processed_images_ai/menu-*.png', { eager: true });
const menuImages = Object.values(menuImagesGlob).map(m => m.default);

const altTexts = [
  "户外婚礼烤猪准备",
  "大型宴会酥炸大虾",
  "精美银盘装鲍鱼汤",
  "传统香蕉叶包阿莫克鱼",
  "宴会新鲜炒贡布胡椒蟹",
  "热炉上的姜葱蒸鱼",
  "高棉番茄生菜炒牛肉",
  "高棉风味咖喱鸡配面包",
  "宴会竹笋炖猪肉",
  "精美摆盘的酥脆炸春卷",
  "冰镇新鲜生蚝",
  "大锅海鲜炒饭",
  "新鲜综合水果盘",
  "忙碌备餐的服务生团队",
  "宴会灯光下的丰盛餐桌"
];

// 過濾：只抓取 zh/ 目錄下的中文文章
const allPostsRaw = await getCollection('blog', ({ id }) => id.startsWith('zh/'));
const allPosts = [...allPostsRaw].sort((a, b) => b.id.localeCompare(a.id));

// 優先挑選標記為 featured 的文章
const featuredPosts = allPosts.filter(post => post.data.featured);
const otherPosts = allPosts.filter(post => !post.data.featured);
const recentPosts = [...featuredPosts, ...otherPosts].slice(0, 3);
---
<Layout title="主厨钟光明 - CKM 金边外烩与办桌服务" description="为金边企业活动与婚宴提供实在的外烩服务。注重场地动线规划、生熟食分离，以及出餐温度的控管。" lang="zh">


  <style>
    .font-zh-serif { font-family: 'Noto Serif SC', serif; }
    .font-zh-sans { font-family: sans-serif; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>

  <article class="w-full">
      <header class="relative min-h-screen flex items-center justify-center overflow-hidden py-20">
        <Image src={heroImageRelative} format="avif" quality={50} alt="CKM团队办桌准备现场" width={1920} height={1080} widths={[400, 768, 1200, 1920]} sizes="100vw" class="absolute inset-0 w-full h-full object-cover object-center transform scale-105" fetchpriority="high" loading="eager" decoding="async" />
        <div class="absolute inset-0 bg-black/70 bg-gradient-to-b from-black/80 via-black/50 to-slate-900/90"></div>
        
        <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-10">
            <Image src={logo} format="avif" alt="CKM 标志" width={176} height={176} widths={[128, 176, 256]} sizes="(max-width: 768px) 128px, 176px" class="w-32 h-32 md:w-44 md:h-44 rounded-full border-4 border-amber-500 mx-auto mb-8 shadow-[0_0_40px_rgba(245,158,11,0.5)]" />
            
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-zh-serif font-bold text-white mb-6 leading-tight">
              主厨 <span class="text-amber-500">钟光明</span>
            </h1>
            
            <h2 class="text-lg md:text-xl font-zh-sans font-medium text-amber-400 mb-6 max-w-2xl mx-auto leading-relaxed">
              CKM团队拥有60年经验，是金边老字号的专业外烩团队。专营传统柬式婚宴、中式办桌与各类聚会。
            </h2>
            
            <p class="text-base md:text-lg text-gray-200 mb-10 max-w-3xl mx-auto font-zh-sans font-light leading-relaxed">
              我们踏实准备每一场宴会。凭借长年累积的经验，希望能为您分担准备工作的辛劳，让您与宾客都能安心享受这场聚会。
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center w-full max-w-md mx-auto sm:max-w-none">
                <a href={`tel:+855${mainPhone.replace(/\\s/g, '').substring(1)}`} class="bg-amber-500 hover:bg-amber-600 text-slate-900 px-6 py-4 rounded-sm font-zh-sans font-bold text-base transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    <span>电话咨询</span>
                </a>
                <a href={telegramLink} target="_blank" rel="noopener noreferrer" class="bg-[#005f8f] hover:bg-[#004b73] text-white px-6 py-4 rounded-sm font-zh-sans font-medium text-base transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                    <span>专人咨询</span>
                </a>
            </div>
        </div>
      </header>

      <section class="py-12 bg-amber-500 relative z-20 shadow-xl">
        <div class="max-w-5xl mx-auto px-6">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center divide-x divide-amber-600/30">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-950 mb-2">60+</span>
              <span class="text-slate-800 text-sm font-zh-sans font-medium">年外烩经验</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-950 mb-2">1万+</span>
              <span class="text-slate-800 text-sm font-zh-sans font-medium">服务过的客户</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-950 mb-2">实在</span>
              <span class="text-slate-800 text-sm font-zh-sans font-medium">稳定出餐品质</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-950 mb-2">确实</span>
              <span class="text-slate-800 text-sm font-zh-sans font-medium">落实卫生标准</span>
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="py-20 bg-slate-50 relative">
         <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
              <h2 class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-900 mb-4">我们提供的核心服务</h2>
              <p class="text-slate-600 font-zh-sans max-w-2xl mx-auto">我们希望能分担您的筹备压力，提供以下几项实在的服务。</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                 <article class="bg-white p-8 rounded-lg border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
                    <div class="w-14 h-14 bg-amber-50 rounded-full flex items-center justify-center mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    </div>
                    <h3 class="text-xl font-zh-serif font-bold text-slate-900 mb-4">柬式传统婚宴办桌与场地布置</h3>
                    <p class="text-slate-600 font-zh-sans leading-relaxed">
                      我们协助准备柬埔寨传统婚宴的菜色，并提供搭棚、场地布置等服务，希望能减轻您自行筹备的负担。
                    </p>
                 </article>
                 
                 <article class="bg-white p-8 rounded-lg border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
                    <div class="w-14 h-14 bg-amber-50 rounded-full flex items-center justify-center mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>
                    </div>
                    <h3 class="text-xl font-zh-serif font-bold text-slate-900 mb-4">中式宴席与企业聚餐</h3>
                    <p class="text-slate-600 font-zh-sans leading-relaxed">
                      无论是家族聚会、传统节日还是公司聚餐，我们准备了多款经典菜色，期盼能为您招待贵宾时增添光彩。
                    </p>
                 </article>
                 
                 <article class="bg-white p-8 rounded-lg border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
                    <div class="w-14 h-14 bg-amber-50 rounded-full flex items-center justify-center mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                    </div>
                    <h3 class="text-xl font-zh-serif font-bold text-slate-900 mb-4">饮水服务与现场应变</h3>
                    <p class="text-slate-600 font-zh-sans leading-relaxed">
                      我们有专人负责饮料与水电配置。遇到天气不佳或突发状况时，我们会尽速协调解决，努力让活动顺利进行。
                    </p>
                 </article>
            </div>
         </div>
      </section>

      <section id="guarantee" class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-6">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-900 mb-4">我们的坚持与承诺</h2>
            <p class="text-slate-600 font-zh-sans">我们踏实做事，真诚对待每一位客人。</p>
          </div>
          
          <div class="space-y-8">
            <div class="flex flex-col md:flex-row gap-6 items-start p-6 rounded-xl bg-slate-50 border border-slate-100">
              <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <div>
                <h3 class="text-xl font-zh-serif font-bold text-slate-900 mb-2">稳定的菜色口味</h3>
                <p class="text-slate-600 font-zh-sans leading-relaxed">
                  我们按部就班烹调，努力让每次出餐的口味都保持一致，无论是大型还是小型活动，都希望能让宾客满意。
                </p>
              </div>
            </div>

            <div class="flex flex-col md:flex-row gap-6 items-start p-6 rounded-xl bg-slate-50 border border-slate-100">
              <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <h3 class="text-xl font-zh-serif font-bold text-slate-900 mb-2">准时上菜</h3>
                <p class="text-slate-600 font-zh-sans leading-relaxed">
                  我们了解时间安排的重要性，因此努力配合流程，按时端上热腾腾的菜肴，不让客人久候。
                </p>
              </div>
            </div>

            <div class="flex flex-col md:flex-row gap-6 items-start p-6 rounded-xl bg-slate-50 border border-slate-100">
              <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h3 class="text-xl font-zh-serif font-bold text-slate-900 mb-2">注重环境与饮食卫生</h3>
                <p class="text-slate-600 font-zh-sans leading-relaxed">
                  从食材准备、烹调到餐具清洗，我们皆遵守卫生要求，希望能提供安心的饮食体验。
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="gallery" class="py-20 bg-slate-50 border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-900 mb-4">外烩现场与经典菜色</h2>
            <p class="text-slate-600 font-zh-sans">CKM 团队外烩现场的实际影像记录</p>
          </div>
          
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
            {menuImages.map((img, index) => (
              <div class="rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                  <Image src={img} alt={altTexts[index] || `经典菜色 ${index + 1}`} width={400} height={400} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="blog" class="py-20 bg-white border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-900 mb-4">外烩筹划的相关知识</h2>
            <p class="text-slate-600 font-zh-sans">了解更多关于外烩活动的准备与经验分享</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {recentPosts.map(post => {
              const slug = post.id.replace(/^zh\//, '').replace(/\.mdx?$/, '');
              return (
                <a href={`/zh/blog/${slug}`} class="group block h-full">
                  <article class="bg-white rounded-lg border border-slate-200 shadow-sm group-hover:shadow-md transition-all duration-300 overflow-hidden flex flex-col h-full">
                    {post.data.coverImage && (
                      <div class="w-full aspect-[16/9] overflow-hidden bg-slate-100">
                        <Image src={post.data.coverImage} alt={post.data.title} width={600} height={337} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                      </div>
                    )}
                    <div class="p-6 flex flex-col flex-grow">
                      <h3 class="text-xl font-zh-serif font-bold text-slate-900 group-hover:text-amber-600 transition-colors duration-300 mb-3 line-clamp-2">{post.data.title}</h3>
                      <p class="text-slate-600 font-zh-sans text-sm mb-6 line-clamp-3">{post.data.description}</p>
                      <div class="mt-auto text-amber-600 font-bold font-zh-sans group-hover:text-amber-700 transition-colors flex items-center gap-2">
                        阅读更多 <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      </div>
                    </div>
                  </article>
                </a>
              );
            })}
          </div>
          
          <div class="text-center mt-12">
             <a href="/blog" class="inline-flex items-center justify-center gap-2 bg-slate-900 hover:bg-slate-800 text-white px-8 py-4 rounded-sm font-zh-sans font-bold transition-colors shadow-md">
               全部文章
             </a>
          </div>
        </div>
      </section>

      <section id="contact" class="py-20 bg-slate-900 relative">
          <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
              <h2 class="text-3xl md:text-4xl font-zh-serif font-bold text-white mb-6">需要讨论您的活动需求吗？</h2>
              <p class="text-slate-300 font-zh-sans mb-10">
                  欢迎随时与我们联系，讨论您的想法。
              </p>
              
              <div class="bg-slate-800 p-8 rounded-lg inline-block w-full max-w-2xl text-left border border-slate-700">
                  <div class="flex flex-col md:flex-row gap-8 items-center justify-between">
                      <div>
                          <p class="text-slate-400 font-zh-sans text-sm mb-4">联系电话：</p>
                          <div class="flex flex-col gap-3 mb-6">
                              {phoneNumbers.map((contact) => (
                                  <a href={`tel:+855${contact.num.replace(/\\s/g, '').substring(1)}`} class="flex items-center gap-3 group">
                                      <div class="w-10 h-10 rounded-full bg-slate-900 border border-slate-700 flex items-center justify-center group-hover:border-amber-500 transition-colors" set:html={contact.svg} />
                                      <div>
                                          <span class="text-lg font-bold text-amber-500 font-sans tracking-wider block leading-none group-hover:text-amber-400 transition-colors">{contact.num}</span>
                                          <span class="text-xs text-slate-500 font-sans uppercase tracking-widest">{contact.type}</span>
                                      </div>
                                  </a>
                              ))}
                          </div>
                          <p class="text-slate-400 font-zh-sans text-sm">地址：金边市 堆谷区 德洛呵2分区 257街 33号</p>
                      </div>
                      
                      <div class="flex gap-4">
                          <a href={telegramLink} target="_blank" rel="noopener noreferrer" aria-label="Telegram 联系" class="w-14 h-14 rounded-full bg-[#005f8f] hover:bg-[#004b73] flex items-center justify-center text-white transition-colors">
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                          </a>
                          <a href={facebookLink} target="_blank" rel="noopener noreferrer" aria-label="Facebook 专页" class="w-14 h-14 rounded-full bg-[#1877F2] hover:bg-[#166FE5] flex items-center justify-center text-white transition-colors">
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                          </a>
                      </div>
                  </div>
              </div>
          </div>
      </section>
  </article>
</Layout>
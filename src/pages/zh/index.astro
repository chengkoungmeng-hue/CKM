---
// 實體路徑: src/pages/zh/index.astro
// 狀態: 終極渲染封裝 4.3 (LCP 悖論修復 + 幾何矩陣啟動 + 絕對對比度合規)
import Layout from '../../layouts/Layout.astro'; 
import { Image } from 'astro:assets'; 

import { 
  siteDomain, 
  telegramLink, 
  facebookLink, 
  heroImageRelative, 
  logo, 
  mainPhone, 
  phoneNumbers, 
  menuItems as allMenuItems, 
  blogPosts as allBlogPosts 
} from '../../data/homeData';

const menuItems = allMenuItems.zh;
const blogPosts = allBlogPosts.zh;
---
<Layout title="主厨钟光明 - CKM 金边专业外烩与办桌团队" description="专为金边大型公司活动与婚宴打造的外烩方案。扎实的场地评估、严格的生熟隔离卫生防线，以及对抗环境温度的确实把关。" lang="zh">
  <Fragment slot="head">
    <link rel="preload" as="image" href={heroImageRelative} fetchpriority="high" />
    
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
    
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FoodEstablishment",
      "name": "CKM Premium Catering (主厨钟光明)",
      "image": "https://www.ckmkh.com/images/home/brand-ckm-logo-gold.webp",
      "description": "专为金边大型公司活动与婚宴打造的外烩方案。扎实的场地评估与严格的生熟隔离卫生防线。",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "257街 33号, 德洛呵2分区, 堆谷区",
        "addressLocality": "Phnom Penh",
        "addressRegion": "Phnom Penh",
        "addressCountry": "KH"
      },
      "telephone": "+85511827782",
      "url": "https://www.ckmkh.com/zh/",
      "servesCuisine": ["Khmer Cuisine", "Chinese Banquet"],
      "priceRange": "$$$$",
      "sameAs": [
        "https://www.facebook.com/CKMFOODS",
        "https://t.me/CKMSam06"
      ]
    })} />
  </Fragment>

  <style>
    .font-zh-serif { font-family: 'Noto Serif SC', serif; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>

  <div class="w-full">
      <header class="relative h-screen flex items-center justify-center overflow-hidden">
        <Image src={heroImageRelative} alt="CKM Luxury Banquet Setup" width={1920} height={1080} class="absolute inset-0 w-full h-full object-cover object-center transform scale-105" fetchpriority="high" loading="eager" decoding="sync" />
        <div class="absolute inset-0 bg-black/70 bg-gradient-to-b from-black/80 via-black/50 to-slate-900/90"></div>
        
        <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-10">
            <Image src={logo} alt="CKM Logo" width={176} height={176} widths={[128, 176, 256]} sizes="(max-width: 768px) 128px, 176px" class="w-32 h-32 md:w-44 md:h-44 rounded-full border-4 border-amber-500 mx-auto mb-8 shadow-[0_0_40px_rgba(245,158,11,0.5)]" />
            <h1 class="text-4xl md:text-6xl font-zh-serif font-bold text-white mb-6 tracking-widest">主厨 <span class="text-amber-500">钟光明</span></h1>
            <h2 class="text-xl md:text-2xl font-sans font-medium text-white/90 mb-6 tracking-[0.2em] uppercase">金边专业外烩与办桌团队</h2>
            <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-2xl mx-auto font-sans font-light leading-relaxed tracking-wide hidden sm:block">专为大型公司活动与企业婚宴打造，靠扎实硬体与经验把关出餐品质。</p>
            
            <div class="flex flex-row gap-3 justify-center animate-fade-in-up w-full max-w-sm mx-auto sm:max-w-none" style="animation-delay: 0.1s;">
                <a href={`tel:+855${mainPhone.replace(/\s/g, '').substring(1)}`} class="flex-1 sm:flex-none bg-amber-500 hover:bg-amber-600 text-slate-900 px-2 sm:px-8 py-3 sm:py-4 min-h-[48px] rounded-sm font-sans font-bold text-sm sm:text-base uppercase tracking-widest transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 md:w-5 md:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    <span class="whitespace-nowrap">电话联系</span>
                </a>
                <a href={telegramLink} target="_blank" rel="noopener noreferrer" class="flex-1 sm:flex-none bg-[#005f8f] hover:bg-[#004b73] text-white px-2 sm:px-8 py-3 sm:py-4 min-h-[48px] rounded-sm font-sans font-medium text-sm sm:text-base uppercase tracking-widest transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                    <span class="whitespace-nowrap">专人咨询</span>
                </a>
            </div>
        </div>
      </header>

      <section class="py-12 bg-amber-500 relative z-20 shadow-xl">
        <div class="max-w-7xl mx-auto px-6">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center divide-x divide-amber-600/30">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-5xl font-serif font-bold text-slate-950 mb-1 md:mb-2 tracking-wider">60+</span>
              <span class="text-slate-800 text-xs md:text-sm font-sans font-medium uppercase tracking-widest">年办桌经验</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <div class="h-[28px] md:h-[48px] flex items-center mb-1 md:mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-10 md:h-10 text-slate-950 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              </div>
              <span class="text-slate-800 text-xs md:text-sm font-sans font-medium uppercase tracking-widest">扎实出餐品质</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <div class="h-[28px] md:h-[48px] flex items-center mb-1 md:mb-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-10 md:h-10 text-slate-950 opacity-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/><line x1="6" y1="17" x2="18" y2="17"/></svg>
              </div>
              <span class="text-slate-800 text-xs md:text-sm font-sans font-medium uppercase tracking-widest">总铺师手路菜</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-5xl font-serif font-bold text-slate-950 mb-1 md:mb-2 tracking-wider">100%</span>
              <span class="text-slate-800 text-xs md:text-sm font-sans font-medium uppercase tracking-widest">严格卫生把关</span>
            </div>
          </div>
        </div>
      </section>

      <section id="service" class="py-16 md:py-24 bg-slate-900 relative overflow-hidden">
         <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="text-center mb-12 md:mb-16"><h2 class="text-3xl md:text-4xl font-zh-serif font-bold text-white tracking-widest">办桌现场硬实力把关</h2></div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                 <div class="bg-slate-800/50 p-8 md:p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-6 md:mb-8">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22"/><line x1="17" y1="5" x2="12" y2="10"/><line x1="7" y1="5" x2="12" y2="10"/><line x1="22" y1="12" x2="2" y2="12"/><line x1="19" y1="17" x2="14" y2="12"/><line x1="19" y1="7" x2="14" y2="12"/><line x1="5" y1="17" x2="10" y2="12"/><line x1="5" y1="7" x2="10" y2="12"/><line x1="17" y1="19" x2="12" y2="14"/><line x1="7" y1="19" x2="12" y2="14"/></svg>
                    </div>
                    <h3 class="text-xl md:text-2xl font-zh-serif font-bold text-white mb-3 md:mb-4 tracking-wider">食材低温保鲜防线</h3>
                    <p class="text-gray-400 text-sm md:text-base font-sans font-light leading-relaxed">不管户外场地条件多严苛，坚持以低温冷藏设备运送与保存海鲜肉类。绝不在食材的新鲜度上妥协，守住办桌的最基本底线。</p>
                 </div>
                 <div class="bg-slate-800/50 p-8 md:p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-6 md:mb-8">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <h3 class="text-xl md:text-2xl font-zh-serif font-bold text-white mb-3 md:mb-4 tracking-wider">百桌出菜温度掌控</h3>
                    <p class="text-gray-400 text-sm md:text-base font-sans font-light leading-relaxed">靠精确的排程与动线管理，不管是一桌还是上百桌，都能对抗户外的环境变数，确保热汤热菜端上桌时，依然保持刚出炉的烫口与风味。</p>
                 </div>
                 <div class="bg-slate-800/50 p-8 md:p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-6 md:mb-8">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                    </div>
                    <h3 class="text-xl md:text-2xl font-zh-serif font-bold text-white mb-3 md:mb-4 tracking-wider">严格的生熟食隔离</h3>
                    <p class="text-gray-400 text-sm md:text-base font-sans font-light leading-relaxed">不喊空泛的口号。在现场临时厨房严格执行生食与熟食物理分开处理，起锅前必定确认中心温度达到杀菌标准，让主家与宾客都吃得安心。</p>
                 </div>
            </div>
         </div>
      </section>

      <section id="portfolio" class="py-16 md:py-24 bg-white overflow-hidden">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-10 md:mb-16"><h2 class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-900 tracking-widest">办桌经典手路菜</h2></div>
          
          <div class="flex overflow-x-auto md:grid md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8 pb-6 -mx-6 px-6 md:mx-0 md:px-0 snap-x snap-mandatory scrollbar-hide">
            {menuItems.map((item) => (
                <div class="group relative overflow-hidden rounded-sm shadow-md bg-slate-50 flex-none w-[80%] sm:w-[50%] md:w-auto snap-center snap-always">
                    <div class="aspect-square overflow-hidden relative bg-slate-200">
                      <Image src={item.image} alt={item.title} width={640} height={640} widths={[400, 640, 800]} sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw" decoding="async" loading="lazy" class="w-full h-full object-cover transform group-hover:scale-105 transition duration-700"/>
                      <div class="absolute inset-0 bg-gradient-to-t from-slate-900/95 via-slate-900/30 to-transparent opacity-85 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    <div class="absolute inset-0 flex flex-col justify-end p-5 md:p-8 pointer-events-none">
                      <h3 class="text-lg md:text-xl font-zh-serif font-bold text-amber-400 mb-2 md:mb-3 md:translate-y-4 md:group-hover:translate-y-0 transition duration-500 tracking-wider">{item.title}</h3>
                      <p class="text-gray-200 text-xs md:text-sm font-sans font-light leading-relaxed md:opacity-0 md:group-hover:opacity-100 transform md:translate-y-4 md:group-hover:translate-y-0 transition-all duration-500 delay-100 line-clamp-3 md:line-clamp-none">{item.desc}</p>
                    </div>
                </div>
            ))}
          </div>
        </div>
      </section>

      <section id="insights" class="py-16 md:py-24 bg-slate-50 border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-6">
           <div class="text-center mb-10 md:mb-16"><h2 class="text-3xl md:text-4xl font-zh-serif font-bold text-slate-900 tracking-widest">外烩办桌实战经验</h2></div>
           <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
              {blogPosts.map(post => (
                <div class="group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-500 border border-slate-100 flex flex-col">
                   <a href={post.link} class="block aspect-[16/9] overflow-hidden relative bg-slate-200">
                      <Image src={post.image} alt={post.title} width={640} height={360} widths={[400, 640, 800]} sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw" decoding="async" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition duration-700"/>
                   </a>
                   <div class="p-6 md:p-8 flex flex-col flex-grow">
                      <h3 class="text-lg md:text-xl font-zh-serif font-bold text-slate-900 mb-2 md:mb-3 group-hover:text-amber-600 transition-colors duration-300 leading-snug tracking-wider">{post.title}</h3>
                      <p class="text-slate-500 text-xs md:text-sm font-sans font-light mb-4 md:mb-6 tracking-wide">{post.subTitle}</p>
                      
                      <a href={post.link} aria-label={`探索专栏: ${post.title}`} class="mt-auto inline-flex items-center text-amber-600 text-xs md:text-sm font-sans font-medium uppercase tracking-widest hover:text-amber-700 transition-colors">
                          探索专栏 
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      </a>
                   </div>
                </div>
              ))}
           </div>
        </div>
      </section>

      <section id="contact" class="relative py-20 md:py-32 bg-slate-950 border-t border-slate-800 overflow-hidden">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-[1px] bg-gradient-to-r from-transparent via-amber-500/30 to-transparent"></div>
          
          <div class="max-w-7xl mx-auto px-6 relative z-10">
              <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-16 lg:gap-8 items-center">
                  <div class="lg:col-span-5 text-left text-center lg:text-left">
                      <div class="inline-flex items-center gap-4 mb-6 md:mb-8">
                          <span class="w-8 md:w-12 h-[1px] bg-amber-500"></span>
                          <span class="text-amber-500 text-[10px] md:text-xs font-sans font-medium tracking-[0.2em] uppercase">活动咨询专线</span>
                          <span class="w-8 h-[1px] bg-amber-500 lg:hidden"></span>
                      </div>
                      <h2 class="text-3xl md:text-4xl lg:text-5xl font-zh-serif font-bold text-white mb-6 md:mb-8 leading-tight tracking-widest">联系办桌统筹</h2>
                      <p class="text-slate-400 text-sm md:text-lg font-sans font-light leading-relaxed mb-8 md:mb-10 max-w-md mx-auto lg:mx-0 tracking-wide">
                          一场顺利圆满的外烩办桌，必须从确认场地硬体设施与出餐动线开始。欢迎联系我们进行详细评估。
                      </p>
                  </div>

                  <div class="lg:col-span-7 lg:col-start-6">
                      <div class="bg-slate-900 border border-slate-800 p-6 md:p-12 rounded-sm shadow-2xl">
                          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4 mb-6 md:mb-10">
                              {phoneNumbers.map((contact) => (
                                  <a href={`tel:+855${contact.num.replace(/\s/g, '').substring(1)}`} class="group flex items-center p-4 md:p-6 rounded-sm bg-slate-950 border border-slate-800 hover:border-amber-500/50 transition-colors duration-300 min-h-[64px] md:min-h-[88px]">
                                      <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-900 flex items-center justify-center shrink-0 mr-4 group-hover:bg-amber-500/10 transition-colors">
                                        <div set:html={contact.svg} />
                                      </div>
                                      <div>
                                        <div class="text-white font-sans font-semibold text-base md:text-lg tracking-wide">{contact.num}</div>
                                        <div class="text-slate-500 text-[10px] md:text-xs font-sans uppercase tracking-[0.2em] mt-0.5 md:mt-1">{contact.type}</div>
                                      </div>
                                  </a>
                              ))}
                              
                              <div class="flex items-center gap-3 md:gap-4 p-4 md:p-6 rounded-sm bg-slate-950 border border-slate-800 min-h-[64px] md:min-h-[88px]">
                                  <a href={telegramLink} target="_blank" rel="noopener noreferrer" aria-label="Telegram" class="flex-1 h-10 md:h-12 rounded-sm bg-[#005f8f] hover:bg-[#004b73] flex items-center justify-center text-white transition-colors duration-300">
                                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                                  </a>
                                  <a href={facebookLink} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex-1 h-10 md:h-12 rounded-sm bg-[#1877F2] hover:bg-[#166FE5] flex items-center justify-center text-white transition-colors duration-300">
                                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                                  </a>
                              </div>
                          </div>
                          
                          <div class="pt-6 md:pt-8 border-t border-slate-800">
                              <div class="flex items-start gap-4 md:gap-6">
                                  <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-950 border border-slate-800 flex items-center justify-center shrink-0">
                                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-6 md:h-6 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                  </div>
                                  <div>
                                      <h4 class="text-white font-sans font-medium text-xs md:text-sm tracking-[0.2em] uppercase mb-1.5 md:mb-2">金边服务据点</h4>
                                      <p class="text-slate-400 text-xs md:text-sm font-sans font-light leading-relaxed tracking-wide">
                                          金边市 堆谷区 德洛呵2分区<br class="hidden sm:block"/>257街 33号
                                      </p>
                                  </div>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>
          </div>
      </section>
  </div>
</Layout>
---
// src/pages/404.astro
// бһҹбҹ’бһҗбһ¶бһ“бһ—бһ¶бһ–бҹ– бһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·бһҖбһ¶бһҡбҹ” бһ‘бҹҶбһ–бҹҗбһҡ 404 бһҖбҹҶбһҺбһҸбҹӢбһ•бҹ’бһӣбһјбһңбһҸбҹ’бһҡбһЎбһ”бҹӢбһ‘бҹ…бһ‘бҹҶбһ–бҹҗбһҡбһҠбһҫбһҳбһҠбҹ„бһҷбһҹбҹ’бһңбҹҗбһҷбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·бҹ” (бһ”бһ¶бһ“бһ’бҹ’бһңбһҫбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“бһ—бһ¶бһ–бһҲбҹ’бһҳбҹ„бҹҮбһ”бҹ’бһҡбҹҒбһ“ бһ“бһ·бһ„ Lucide SVG)
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - бһ‘бҹҶбһ–бҹҗбһҡбһҳбһ·бһ“бһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһҡбһҖбһғбһҫбһү | бһ…бһ»бһ„бһ—бҹ… бһ…бҹҒбһ„ бһӮбһҪбһ„бһҳбҹүбҹҒбһ„ - CKM Catering Services" description="Page Not Found" lang="km">
  <Fragment slot="head">
    <meta http-equiv="refresh" content="10;url=/" />
  </Fragment>

  <div class="min-h-screen bg-slate-950 flex flex-col items-center justify-center px-6 relative overflow-hidden">
    
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(245,158,11,0.08)_0%,transparent_60%)]"></div>

    <div class="relative z-10 text-center max-w-2xl mx-auto mt-[-10vh]">
      <h1 class="text-8xl md:text-[150px] font-serif font-bold text-amber-500 mb-2 leading-none drop-shadow-[0_0_40px_rgba(245,158,11,0.3)]">
        404
      </h1>
      
      <h2 class="text-xl md:text-3xl font-sans font-medium text-white mb-6 uppercase tracking-wider">
        бһ‘бҹҶбһ–бҹҗбһҡбһҳбһ·бһ“бһҸбҹ’бһҡбһјбһңбһ”бһ¶бһ“бһҡбһҖбһғбһҫбһү <span class="hidden md:inline text-slate-600 mx-2">|</span> <br class="md:hidden" /> <span class="text-slate-300">Page Not Found</span>
      </h2>
      
      <p class="text-slate-400 font-sans font-light mb-12 text-lg md:text-xl">
        бһ”бҹ’бһҡбһ–бҹҗбһ“бҹ’бһ’бһҖбҹҶбһ–бһ»бһ„бһ”бһүбҹ’бһҮбһјбһ“бһўбҹ’бһ“бһҖбһҸбҹ’бһҡбһЎбһ”бҹӢбһ‘бҹ…бһ‘бҹҶбһ–бҹҗбһҡбһҠбһҫбһҳбһңбһ·бһүбһҖбҹ’бһ“бһ»бһ„бһҡбһҷбҹҲбһ–бҹҒбһӣ 
        <span id="countdown" class="text-amber-500 font-bold text-2xl inline-block w-8 text-center">10</span> 
        бһңбһ·бһ“бһ¶бһ‘бһё...
      </p>

      <a href="/" class="inline-flex items-center justify-center gap-3 bg-amber-500 hover:bg-amber-400 text-slate-950 px-10 py-4 min-h-[56px] rounded-sm font-sans font-bold tracking-widest uppercase transition-all shadow-[0_0_20px_rgba(245,158,11,0.25)] hover:shadow-[0_0_30px_rgba(245,158,11,0.5)] focus:ring-2 focus:ring-amber-300 focus:outline-none">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        бһҸбҹ’бһҡбһЎбһ”бҹӢбһ‘бҹ…бһ‘бҹҶбһ–бҹҗбһҡбһҠбһҫбһҳ
      </a>
    </div>
  </div>

  <script is:inline>
    // бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҖбҹҶбһҺбһҸбҹӢбһҳбҹүбҹ„бһ„бһ”бһүбҹ’бһҮбһјбһ“бһ”бһ“бҹ’бһҸ (Client-side countdown timer)
    let timeLeft = 10;
    const countdownEl = document.getElementById('countdown');
    
    const timer = setInterval(() => {
      timeLeft--;
      if (countdownEl) {
        countdownEl.innerText = timeLeft;
      }
      
      if (timeLeft <= 0) {
        clearInterval(timer);
        window.location.href = '/';
      }
    }, 1000);
  </script>
</Layout>

<style>
  /* бһӣбһ¶бһҖбҹӢ Navbar бһ“бһ·бһ„ Footer бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢбһ‘бҹҶбһ–бҹҗбһҡ 404 (Force hide global elements) */
  :global(nav), :global(footer), :global(.fixed.bottom-0) {
    display: none !important;
  }
</style>
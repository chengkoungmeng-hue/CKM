---
// 實體路徑: src/pages/[lang]/blog/[slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro'; 

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => {
    const [lang, ...slugParts] = entry.slug.split('/');
    const slug = slugParts.join('/');
    return {
      params: { lang, slug },
      props: { entry },
    };
  });
}

const { lang, slug } = Astro.params;
const { entry } = Astro.props;
const { Content } = await entry.render();

const { title, seoTitle, description, coverImage, targetGeo, authoritySignals } = entry.data;
const baseUrl = "https://www.ckmkh.com";
const currentUrl = `${baseUrl}/${lang}/blog/${slug}`;

// 智慧多語系字典
const translations = {
  km: { tag: "ទស្សនៈចុងភៅកម្រិតកំពូល", author: "រៀបរៀងដោយ៖ ចុងភៅ ជុង ក្វាងមីង", back: "ត្រឡប់ទៅទំព័រដើម" },
  zh: { tag: "顶级宴会统筹智库", author: "撰文：主厨 钟光明", back: "返回首页" },
  en: { tag: "Premium Catering Insights", author: "By Executive Chef Cheng Kuongmeng", back: "Return to Home" }
};
const t = translations[lang as keyof typeof translations] || translations.zh;

const formattedDate = entry.data.date 
  ? entry.data.date.toLocaleDateString(
      lang === 'km' ? 'km-KH' : lang === 'zh' ? 'zh-CN' : 'en-US', 
      { year: 'numeric', month: 'long', day: 'numeric' }
    )
  : null;
---

<Layout title={seoTitle || title} description={description} lang={lang}>
  <Fragment slot="head">
    <link rel="canonical" href={currentUrl} />
    <link rel="alternate" hreflang="km-KH" href={`${baseUrl}/km/blog/${slug}`} />
    <link rel="alternate" hreflang="zh-CN" href={`${baseUrl}/zh/blog/${slug}`} />
    <link rel="alternate" hreflang="en-US" href={`${baseUrl}/en/blog/${slug}`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/km/blog/${slug}`} />
    <meta name="geo.placename" content={targetGeo} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Noto+Serif+SC:wght@600;700&family=Hanuman:wght@400;700&family=Kantumruy+Pro:wght@300;400;500&display=swap" rel="stylesheet">
  </Fragment>

  <div class={`bg-slate-50 min-h-screen pt-28 pb-24 selection:bg-amber-200 selection:text-slate-900 typo-${lang}`}>
      <article class="max-w-4xl mx-auto px-5 sm:px-8">
        
        <header class="mb-10 text-center">
          <div class="inline-block bg-slate-200 text-slate-700 px-4 py-1.5 rounded-sm text-xs font-bold tracking-widest uppercase mb-6 shadow-sm border border-slate-300">
            {t.tag}
          </div>
          
          <h1 class="text-3xl md:text-5xl font-bold mb-6 text-slate-900 leading-snug">
            {title}
          </h1>
          
          <div class="flex items-center justify-center gap-4 text-slate-500 text-sm py-3">
            <span class="text-amber-600 font-bold tracking-wider uppercase">{t.author}</span>
            {formattedDate && (
              <>
                <span class="text-slate-300">|</span>
                <time class="tracking-widest font-light">{formattedDate}</time>
              </>
            )}
          </div>
        </header>
        
        <div class="w-full aspect-[16/9] md:aspect-[21/9] overflow-hidden bg-slate-200 rounded-sm shadow-xl mb-12 border border-slate-200/60">
          <img src={coverImage} alt={seoTitle || title} class="w-full h-full object-cover" loading="eager" />
        </div>
        
        <div class="flex flex-wrap justify-center gap-3 mb-12 border-b border-slate-200 pb-12">
            {authoritySignals.map(signal => (
              <span class="bg-white text-slate-700 px-4 py-2 text-sm font-bold border border-slate-200 shadow-sm rounded-sm">
                <i class="fas fa-check-circle text-amber-500 mr-2"></i>{signal}
              </span>
            ))}
        </div>
    
        <div class="ckm-prose mx-auto bg-white p-6 md:p-16 rounded-sm shadow-md border border-slate-100">
          <Content />
        </div>

        <div class="mt-16 text-center">
            <a href={`/${lang}/`} class="inline-flex items-center justify-center bg-slate-900 hover:bg-amber-600 text-white px-10 py-4 rounded-sm font-bold tracking-widest uppercase transition-colors duration-300 shadow-lg">
              <i class="fas fa-arrow-left mr-3"></i> {t.back}
            </a>
        </div>

      </article>
  </div>
</Layout>

<style is:global>
  /* =========================================
     智慧語系字體矩陣 (Typography Matrix)
  ========================================= */
  
  /* [英文 EN] Playfair Display 襯線大標 + 優雅無襯線內文 */
  .typo-en h1, .typo-en .ckm-prose h2, .typo-en .ckm-prose h3 { 
    font-family: 'Playfair Display', serif; 
    letter-spacing: 0.02em;
  }
  .typo-en .ckm-prose p, .typo-en .ckm-prose li { 
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
    font-weight: 300; 
  }

  /* [中文 ZH] 思源宋體 Noto Serif SC 大標 + 現代無襯線內文 */
  .typo-zh h1, .typo-zh .ckm-prose h2, .typo-zh .ckm-prose h3 { 
    font-family: 'Noto Serif SC', serif; 
    letter-spacing: 0.05em;
  }
  .typo-zh .ckm-prose p, .typo-zh .ckm-prose li { 
    font-family: system-ui, "PingFang SC", "Microsoft YaHei", sans-serif; 
    font-weight: 300; 
    letter-spacing: 0.05em;
  }

  /* [高棉文 KM] Hanuman 襯線大標 + Kantumruy Pro 無襯線內文 */
  .typo-km h1, .typo-km .ckm-prose h2, .typo-km .ckm-prose h3 { 
    font-family: 'Hanuman', serif; 
  }
  .typo-km .ckm-prose p, .typo-km .ckm-prose li { 
    font-family: 'Kantumruy Pro', sans-serif; 
    font-weight: 300; 
    line-height: 2.2; /* 高棉文需要更大的呼吸空間 */
  }

  /* =========================================
     白皮書高階排版裝甲 (Prose Styling)
  ========================================= */
  .ckm-prose {
    color: #334155; /* slate-700 深灰色內文 */
    font-size: 1.125rem;
    line-height: 1.8;
  }
  .ckm-prose p {
    margin-bottom: 2em;
  }
  .ckm-prose h2 {
    color: #0f172a; /* slate-900 極深灰標題 */
    font-size: 2rem;
    font-weight: 700;
    margin-top: 2.5em;
    margin-bottom: 1em;
    padding-left: 1rem;
    border-left: 4px solid #f59e0b; /* amber-500 金色左邊框收斂為 4px 更顯精緻 */
    line-height: 1.3;
  }
  .ckm-prose h3 {
    color: #1e293b;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2.5em;
    margin-bottom: 1em;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e2e8f0; /* 加入底線增加層次感 */
  }
  .ckm-prose strong {
    color: #0f172a;
    font-weight: 600;
    background-color: rgba(245, 158, 11, 0.1); 
    padding: 0 0.2em;
  }
  .ckm-prose blockquote {
    background-color: #f8fafc;
    border-left: 4px solid #f59e0b;
    padding: 2rem;
    margin: 3rem 0;
    font-size: 1.25rem;
    font-style: italic;
    color: #475569;
    box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.02);
  }
  .ckm-prose ul {
    list-style-type: none; /* 移除預設黑點，改用客製化設計 */
    padding-left: 1rem;
    margin-bottom: 2rem;
  }
  .ckm-prose li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .ckm-prose li::before {
    content: "■"; /* 使用方形符號呼應微圓角/直角的奢華感 */
    color: #f59e0b;
    position: absolute;
    left: 0;
    font-size: 0.6rem;
    top: 0.4rem;
  }
</style>
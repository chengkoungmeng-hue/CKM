            {menuImages.map((img, index) => (
              <div class="rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                  <Image src={img} alt={`бһҳбһ»бһҒбһҳбҹ’бһ бһјбһ”бһҖбһ¶бһҡбһ”бҹ’бһҡбһ–бҹғбһҺбһёбһҒбҹ’бһҳбҹӮбһҡбһ‘бһё${index + 1}`} width={400} height={400} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" />
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="blog" class="py-20 bg-white border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-km-serif font-bold text-slate-900 mb-4">бһўбһҸбҹ’бһҗбһ”бһ‘ бһ“бһ·бһ„бһ…бҹҶбһҺбҹҒбҹҮбһҠбһ№бһ„</h2>
            <p class="text-slate-600 font-km-sans">бһҹбҹ’бһңбҹӮбһ„бһҷбһӣбҹӢбһ”бһ“бҹ’бһҗбҹӮбһҳбһўбҹҶбһ–бһёбһҖбһ¶бһҡбһҡбҹҖбһ”бһ…бҹҶбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһё бһ“бһ·бһ„бһ”бһ‘бһ–бһ·бһҹбҹ„бһ’бһ“бҹҚбһҡбһ”бһҹбҹӢ CKM</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {recentPosts.map(post => {
              const slug = post.id.replace(/\.mdx?$/, '');
              return (
                <a href={`/blog/${slug}`} class="group block h-full">
                  <article class="bg-white rounded-lg border border-slate-200 shadow-sm group-hover:shadow-md transition-all duration-300 overflow-hidden flex flex-col h-full">
                    {post.data.coverImage && (
                      <div class="w-full aspect-[16/9] overflow-hidden bg-slate-100">
                        <Image src={post.data.coverImage} alt={post.data.title} width={600} height={337} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                      </div>
                    )}
                    <div class="p-6 flex flex-col flex-grow">
                      <h3 class="text-xl font-km-serif font-bold text-slate-900 group-hover:text-amber-600 transition-colors duration-300 mb-3 line-clamp-2">{post.data.title}</h3>
                      <p class="text-slate-600 font-km-sans text-sm mb-6 line-clamp-3">{post.data.description}</p>
                      <div class="mt-auto text-amber-600 font-bold font-km-sans group-hover:text-amber-700 transition-colors flex items-center gap-2">
                        бһўбһ¶бһ“бһ”бһ“бҹ’бһҗбҹӮбһҳ <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                      </div>
                    </div>
                  </article>
                </a>
              );
            })}
          </div>
          
          <div class="text-center mt-12">
             <a href="/blog" class="inline-flex items-center justify-center gap-2 bg-slate-900 hover:bg-slate-800 text-white px-8 py-4 rounded-sm font-km-sans font-bold transition-colors shadow-md">
               бһўбһҸбҹ’бһҗбһ”бһ‘бһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢ
             </a>
          </div>
        </div>
      </section>

      <section id="contact" class="py-20 bg-slate-900 relative">
          <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
              <h2 class="text-3xl md:text-4xl font-km-serif font-bold text-white mb-6">бһҸбҹ’бһҡбһјбһңбһҖбһ¶бһҡбһ–бһ·бһ—бһ¶бһҖбҹ’бһҹбһ¶бһўбҹҶбһ–бһёбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёбһҡбһ”бһҹбҹӢбһӣбҹ„бһҖбһўбҹ’бһ“бһҖ?</h2>
              <p class="text-slate-300 font-km-sans mb-10">
                  бһҹбһјбһҳбһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„бһҳбһҖбһҖбһ¶бһ“бҹӢбһҷбһҫбһ„бһҒбҹ’бһүбһ»бҹҶбһҘбһЎбһјбһңбһ“бҹҒбҹҮ бһҠбһҫбһҳбҹ’бһ”бһёбһ‘бһ‘бһҪбһӣбһ”бһ¶бһ“бһҖбһ¶бһҡбһ”бҹ’бһҡбһ№бһҖбҹ’бһҹбһ¶бһҷбҹ„бһ”бһӣбҹӢбһҠбҹ„бһҷбһҘбһҸбһӮбһ·бһҸбһҗбҹ’бһӣбҹғбҹ”
              </p>
              
              <div class="bg-slate-800 p-8 rounded-lg inline-block w-full max-w-2xl text-left border border-slate-700">
                  <div class="flex flex-col md:flex-row gap-8 items-center justify-between">
                      <div>
                          <p class="text-slate-400 font-km-sans text-sm mb-4">бһӣбҹҒбһҒбһ‘бһјбһҡбһҹбҹҗбһ–бҹ’бһ‘бһ‘бҹҶбһ“бһ¶бһҖбҹӢбһ‘бҹҶбһ“бһ„бҹ–</p>
                          <div class="flex flex-col gap-3 mb-6">
                              {phoneNumbers.map((contact) => (
                                  <a href={`tel:+855${contact.num.replace(/\s/g, '').substring(1)}`} class="flex items-center gap-3 group">
                                      <div class="w-10 h-10 rounded-full bg-slate-900 border border-slate-700 flex items-center justify-center group-hover:border-amber-500 transition-colors" set:html={contact.svg} />
                                      <div>
                                          <span class="text-lg font-bold text-amber-500 font-sans tracking-wider block leading-none group-hover:text-amber-400 transition-colors">{contact.num}</span>
                                          <span class="text-xs text-slate-500 font-sans uppercase tracking-widest">{contact.type}</span>
                                      </div>
                                  </a>
                              ))}
                          </div>
                          <p class="text-slate-400 font-km-sans text-sm">бһ‘бһёбһҸбһ¶бҹҶбһ„бҹ– бһ•бҹ’бһ‘бҹҮбһӣбҹҒбһҒ 33 бһ•бҹ’бһӣбһјбһң 257 бһҹбһ„бҹ’бһҖбһ¶бһҸбҹӢбһ‘бһ№бһҖбһӣбҹ’бһўбһҖбҹӢбһ‘бһёбҹў бһҒбһҺбҹ’бһҢбһ‘бһҪбһӣбһӮбҹ„бһҖ бһҡбһ¶бһҮбһ’бһ¶бһ“бһёбһ—бҹ’бһ“бҹҶбһ–бҹҒбһү</p>
                      </div>
                      
                      <div class="flex gap-4">
                          <a href={telegramLink} target="_blank" rel="noopener noreferrer" aria-label="бһ•бҹ’бһүбһҫбһҹбһ¶бһҡбһҸбһ¶бһҳ Telegram" class="w-14 h-14 rounded-full bg-[#005f8f] hover:bg-[#004b73] flex items-center justify-center text-white transition-colors">
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                          </a>
                          <a href={facebookLink} target="_blank" rel="noopener noreferrer" aria-label="бһ‘бҹҶбһ–бҹҗбһҡ Facebook" class="w-14 h-14 rounded-full bg-[#1877F2] hover:bg-[#166FE5] flex items-center justify-center text-white transition-colors">
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                          </a>
                      </div>
                  </div>
              </div>
          </div>
      </section>
  </article>
</Layout>

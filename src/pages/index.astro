---
// 實體路徑: src/pages/index.astro (高棉語主站)
// 狀態: CKM Landing Page Refactor V1.3 (純粹白話文與信賴錨點)
import Layout from '../layouts/Layout.astro'; 
import { Image } from 'astro:assets';
import { Phone, Send, Utensils, Building2, Zap, Award, Clock, Sparkles, ChevronRight } from '@lucide/astro';

import { getCollection } from 'astro:content';

import '@fontsource/hanuman/400.css';
import '@fontsource/hanuman/700.css';
import '@fontsource/kantumruy-pro/300.css';
import '@fontsource/kantumruy-pro/400.css';
import '@fontsource/kantumruy-pro/500.css';
import '@fontsource/kantumruy-pro/600.css';

import { 
  telegramLink, 
  facebookLink, 
  heroImageRelative, 
  logo, 
  mainPhone,
  phoneNumbers
} from '../data/homeData';

const menuImagesGlob = import.meta.glob<{ default: ImageMetadata }>('../assets/processed_images_ai/menu-*.png', { eager: true });
const menuImages = Object.values(menuImagesGlob).map(m => m.default);

const altTexts = [
  "ទិដ្ឋភាពរៀបចំសាច់ជ្រូកខ្វៃស្រួយឆ្ងាញ់ក្នុងពិធីមង្គលការដោយ CKM",
  "បង្កងទន្លេបំពងខ្ទឹមស សេវាកម្មម្ហូបការលំដាប់ខ្ពស់",
  "ស៊ុបប៉ាវហ៊ឺពិសេសក្នុងម៉ឺនុយម្ហូបការ ៨ មុខ",
  "អាម៉ុកត្រីបែបប្រពៃណីខ្មែរសម្រាប់ពិធីជប់លៀង",
  "ក្តាមឆាម្រេចកំពតស្រស់ៗ សម្រាប់កម្មវិធីអាជីវកម្ម",
  "ត្រីចំហុយទឹកស៊ីអ៊ីវ ធានារសជាតិឆ្ងាញ់ថេរ",
  "សាច់គោឡុកឡាក់ វត្ថុធាតុដើមស្រស់ៗគុណភាពខ្ពស់",
  "ការីសាច់មាន់បែបខ្មែរ ចុងភៅរៀបចំម្ហូបការភ្នំពេញ",
  "សាច់ជ្រូកខទំពាំងសម្រាប់ពិធីបុណ្យប្រពៃណីចិន",
  "ណែមបំពងស្រួយ រៀបចំយ៉ាងស្រស់ស្អាតនិងមានអនាម័យ",
  "អយស្ទ័រស្រស់ៗ ក្នុងកម្មវិធីជប់លៀងក្រុមហ៊ុន",
  "បាយឆាគ្រឿងសមុទ្រ សេវាកម្មរៀបចំម្ហូបអាហារ CKM",
  "ថាសផ្លែឈើចម្រុះស្រស់ៗ ការតុបតែងប្រណិត",
  "ក្រុមការងារ CKM ត្រៀមបម្រើសេវាកម្មម្ហូបការ",
  "តុអាហារពិធីជប់លៀងដ៏ប្រណិត និងការគ្រប់គ្រងសីតុណ្ហភាព"
];

// 過濾：只抓取根目錄 (沒有含 '/' 的 id)，代表高棉文原始文章
const allPostsRaw = await getCollection('blog', ({ id }) => !id.includes('/'));
const allPosts = [...allPostsRaw].sort((a, b) => b.id.localeCompare(a.id));

// 優先挑選標記為 featured 的文章
const featuredPosts = allPosts.filter(post => post.data.featured);
const otherPosts = allPosts.filter(post => !post.data.featured);
const recentPosts = [...featuredPosts, ...otherPosts].slice(0, 3);

---
<Layout title="ចេង គួងម៉េង (CKM) | ក្រុមចុងភៅរៀបចំម្ហូបការនៅភ្នំពេញ" description="ក្រុមចុងភៅ CKM គឺជាក្រុមចុងភៅនៅរាជធានីភ្នំពេញដែលមានបទពិសោធន៍ ៦០ ឆ្នាំ ឯកទេសខាងរៀបចំម្ហូបការប្រពៃណីខ្មែរ និងការជួបជុំផ្សេងៗ។" lang="km-KH">


  <style>
    .font-km-serif { font-family: 'Hanuman', serif; }
    .font-km-sans { font-family: 'Kantumruy Pro', sans-serif; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>

  <article class="w-full">
      <header class="relative min-h-screen flex items-center justify-center overflow-hidden py-20">
        <Image src={heroImageRelative} format="avif" quality={50} alt="ទិដ្ឋភាពរៀបចំម្ហូបការដោយក្រុមចុងភៅ CKM" width={1920} height={1080} widths={[400, 768, 1200, 1920]} sizes="100vw" class="absolute inset-0 w-full h-full object-cover object-center transform scale-105" fetchpriority="high" loading="eager" decoding="sync" />
        <div class="absolute inset-0 bg-black/70 bg-gradient-to-b from-black/80 via-black/50 to-slate-900/90"></div>
        
        <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-10">
            <Image src={logo} format="avif" alt="និមិត្តសញ្ញាក្រុមចុងភៅ ចេង គួងម៉េង" width={176} height={176} widths={[128, 176, 256]} sizes="(max-width: 768px) 128px, 176px" class="w-32 h-32 md:w-44 md:h-44 rounded-full border-2 border-champagne/50 mx-auto mb-8 shadow-glow-lg" fetchpriority="high" loading="eager" decoding="sync" />
            
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-km-serif font-bold text-white mb-6 leading-tight">
              ក្រុមចុងភៅ <span class="text-champagne">ចេង គួងម៉េង</span>
            </h1>
            
            <h2 class="text-lg md:text-xl font-km-sans font-medium text-champagne mb-6 max-w-2xl mx-auto leading-relaxed">
              ក្រុមចុងភៅ CKM គឺជាក្រុមចុងភៅនៅរាជធានីភ្នំពេញដែលមានបទពិសោធន៍ ៦០ ឆ្នាំ ឯកទេសខាងរៀបចំម្ហូបការប្រពៃណីខ្មែរ និងការជួបជុំផ្សេងៗ។
            </h2>
            
            <p class="text-base md:text-lg text-gray-200 mb-10 max-w-3xl mx-auto font-km-sans font-light leading-relaxed">
              យើងខ្ញុំផ្តល់ជូន <strong class="text-white font-medium">សេវាកម្មម្ហូបការ</strong> និង <strong class="text-white font-medium">សេវាកម្មរៀបចំម្ហូបអាហារ</strong> គ្រប់ប្រភេទដោយក្តីយកចិត្តទុកដាក់។ ជាមួយនឹងបទពិសោធន៍ដ៏យូរអង្វែង យើងនឹងជួយសម្រួលរាល់កិច្ចការងារ រួមទាំងមានសេវាកម្ម <strong class="text-white font-medium">ការភ្លក្សរសជាតិម្ហូប</strong> ជាមុន ដើម្បីឱ្យលោកអ្នកអាចទទួលភ្ញៀវដោយក្តីរីករាយ និងមិនមានក្តីបារម្ភអ្វីទាំងអស់។
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center w-full max-w-md mx-auto sm:max-w-none">
                <a href={`tel:+855${mainPhone.replace(/\s/g, '').substring(1)}`} class="bg-champagne hover:bg-[#d6b76c] text-onyx px-6 py-4 rounded-sm font-km-sans font-bold text-base transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <Phone class="w-5 h-5" strokeWidth={1.5} />
                    <span>ទូរស័ព្ទសាកសួរព័ត៌មាន</span>
                </a>
                <a href={telegramLink} target="_blank" rel="noopener noreferrer" class="bg-onyx/50 hover:bg-onyx/80 backdrop-blur-sm border border-champagne text-champagne hover:text-white px-6 py-4 rounded-sm font-km-sans font-medium text-base transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <Send class="w-5 h-5" strokeWidth={1.5} />
                    <span>ផ្ញើសារតាមតេឡេក្រាម</span>
                </a>
            </div>
        </div>
      </header>

      <section class="py-12 bg-onyx relative z-20 shadow-xl border-y border-slate-800 reveal">
        <div class="max-w-5xl mx-auto px-6">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center divide-x divide-slate-800">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-km-serif font-bold text-champagne mb-2">៦០+</span>
              <span class="text-slate-400 text-sm font-km-sans font-medium">ឆ្នាំនៃបទពិសោធន៍</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-km-serif font-bold text-champagne mb-2">១ម៉ឺន+</span>
              <span class="text-slate-400 text-sm font-km-sans font-medium">អតិថិជនដែលធ្លាប់បានបម្រើ</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-km-serif font-bold text-champagne mb-2">ឆ្ងាញ់</span>
              <span class="text-slate-400 text-sm font-km-sans font-medium">ធានារសជាតិថេរ</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-4xl font-km-serif font-bold text-champagne mb-2">ស្អាត</span>
              <span class="text-slate-400 text-sm font-km-sans font-medium">អនាម័យជាចម្បង</span>
            </div>
          </div>
        </div>
      </section>

      <section id="services" class="py-20 bg-pearl relative reveal">
         <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
              <h2 class="text-3xl md:text-4xl font-km-serif font-bold text-onyx mb-4">សេវាកម្មចម្បងរបស់យើង</h2>
              <p class="text-slate-600 font-km-sans max-w-2xl mx-auto tracking-widest">យើងខ្ញុំត្រៀមខ្លួនជាស្រេចក្នុងការជួយសម្រួលរាល់ការងារហត់នឿយរបស់លោកអ្នក។</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                 <article class="bg-white p-8 rounded-sm border border-slate-100 shadow-sm hover:shadow-glow transition-all">
                    <div class="w-14 h-14 bg-champagne/10 rounded-full flex items-center justify-center mb-6">
                        <Utensils class="w-7 h-7 text-champagne" strokeWidth={1.5} />
                    </div>
                    <h3 class="text-xl font-km-serif font-bold text-onyx mb-4">រៀបចំម្ហូបការប្រពៃណីខ្មែរ និងតុបតែងទីតាំង</h3>
                    <p class="text-slate-600 font-km-sans leading-relaxed">
                      យើងជួយរៀបចំម្ហូបអាហារសម្រាប់ពិធីសារពាង្គការប្រពៃណីខ្មែរ ព្រមទាំងមានសេវាជួលរោង និងតុបតែងទីតាំងកម្មវិធីឱ្យបានស្អាត និងរៀបរយ។ លោកអ្នកមិនចាំបាច់ហត់នឿយក្នុងការរៀបចំដោយខ្លួនឯងឡើយ។
                    </p>
                 </article>
                 
                 <article class="bg-white p-8 rounded-sm border border-slate-100 shadow-sm hover:shadow-glow transition-all">
                    <div class="w-14 h-14 bg-champagne/10 rounded-full flex items-center justify-center mb-6">
                        <Building2 class="w-7 h-7 text-champagne" strokeWidth={1.5} />
                    </div>
                    <h3 class="text-xl font-km-serif font-bold text-onyx mb-4">ពិធីជប់លៀងបែបចិន និងកម្មវិធីអាជីវកម្ម</h3>
                    <p class="text-slate-600 font-km-sans leading-relaxed">
                      សម្រាប់កម្មវិធីជួបជុំគ្រួសារ ពិធីបុណ្យ ឬការជួបជុំអាជីវកម្ម យើងមាន <strong class="text-onyx font-medium">ម៉ឺនុយម្ហូបការ ៨ មុខ</strong> រួមមានមុខម្ហូបពិសេសៗដូចជា <strong class="text-onyx font-medium">សាច់ជ្រូកខ្វៃ</strong> និង <strong class="text-onyx font-medium">ស៊ុបប៉ាវហឺ</strong> ដែលស័ក្តិសមបំផុតសម្រាប់ទទួលភ្ញៀវកិត្តិយស។
                    </p>
                 </article>
                 
                 <article class="bg-white p-8 rounded-sm border border-slate-100 shadow-sm hover:shadow-glow transition-all">
                    <div class="w-14 h-14 bg-champagne/10 rounded-full flex items-center justify-center mb-6">
                        <Zap class="w-7 h-7 text-champagne" strokeWidth={1.5} />
                    </div>
                    <h3 class="text-xl font-km-serif font-bold text-onyx mb-4">ផ្នែកភេសជ្ជៈ និងការដោះស្រាយបញ្ហាភ្លាមៗ</h3>
                    <p class="text-slate-600 font-km-sans leading-relaxed">
                      យើងមានក្រុមការងារចាំជួយរៀបចំផ្នែកភេសជ្ជៈ និងប្រព័ន្ធភ្លើង។ ទោះបីជាមានបញ្ហាអាកាសធាតុ ភ្លៀងធ្លាក់ ឬដាច់ភ្លើងក៏ដោយ ក៏យើងមានដំណោះស្រាយរួចជាស្រេច ដើម្បីឱ្យកម្មវិធីដើរទៅមុខដោយរលូន។
                    </p>
                 </article>
            </div>
         </div>
      </section>

      <section id="guarantee" class="py-20 bg-white border-t border-slate-100 reveal">
        <div class="max-w-5xl mx-auto px-6">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-km-serif font-bold text-onyx mb-4">ការធានាគុណភាពពី CKM</h2>
            <p class="text-slate-600 font-km-sans tracking-widest">ពួកយើងធ្វើការដោយក្តីស្មោះត្រង់ និងយកចិត្តទុកដាក់បំផុតចំពោះភ្ញៀវរបស់អ្នក។</p>
          </div>
          
          <div class="space-y-6">
            <div class="flex flex-col md:flex-row gap-6 items-start p-8 rounded-sm bg-pearl border border-slate-100 hover:border-champagne/30 transition-colors">
              <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shrink-0 shadow-sm">
                <Award class="w-6 h-6 text-champagne" strokeWidth={1.5} />
              </div>
              <div>
                <h3 class="text-xl font-km-serif font-bold text-onyx mb-2">រសជាតិម្ហូបឆ្ងាញ់ថេរ</h3>
                <p class="text-slate-600 font-km-sans leading-relaxed">
                  យើងចម្អិនដោយយកចិត្តទុកដាក់ ធានាថារសជាតិម្ហូបគឺឆ្ងាញ់ដូចគ្នាគ្រប់កម្មវិធី មិនថាកម្មវិធីរបស់លោកអ្នកតូច ឬធំនោះទេ។ ភ្ញៀវនឹងសរសើរពីរសជាតិម្ហូប។
                </p>
              </div>
            </div>

            <div class="flex flex-col md:flex-row gap-6 items-start p-8 rounded-sm bg-pearl border border-slate-100 hover:border-champagne/30 transition-colors">
              <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shrink-0 shadow-sm">
                <Clock class="w-6 h-6 text-champagne" strokeWidth={1.5} />
              </div>
              <div>
                <h3 class="text-xl font-km-serif font-bold text-onyx mb-2">ពេលវេលាចេញម្ហូប និងការគ្រប់គ្រងសីតុណ្ហភាព</h3>
                <p class="text-slate-600 font-km-sans leading-relaxed">
                  ភ្ញៀវរបស់លោកអ្នកមិនចាំបាច់រង់ចាំយូរឡើយ។ យើងមានទម្លាប់ចេញម្ហូបបានលឿន ព្រមទាំងមាន <strong class="text-onyx font-medium">ការគ្រប់គ្រងសីតុណ្ហភាព</strong> បានល្អ ដើម្បីធានាថាម្ហូបតែងតែក្តៅៗជានិច្ច ស្របតាមពេលវេលាដែលបានកំណត់។
                </p>
              </div>
            </div>

            <div class="flex flex-col md:flex-row gap-6 items-start p-8 rounded-sm bg-pearl border border-slate-100 hover:border-champagne/30 transition-colors">
              <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shrink-0 shadow-sm">
                <Sparkles class="w-6 h-6 text-champagne" strokeWidth={1.5} />
              </div>
              <div>
                <h3 class="text-xl font-km-serif font-bold text-onyx mb-2">វត្ថុធាតុដើមស្រស់ៗ និងអនាម័យជាចម្បង</h3>
                <p class="text-slate-600 font-km-sans leading-relaxed">
                  ចាប់តាំងពីការជ្រើសរើស <strong class="text-onyx font-medium">វត្ថុធាតុដើមស្រស់ៗ</strong> រហូតដល់ការចម្អិន និងលាងសម្អាត យើងអនុវត្តតាមស្តង់ដារសុវត្ថិភាពម្ហូបអាហារ និងអនាម័យខ្ពស់បំផុត។
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="gallery" class="py-20 bg-pearl border-t border-slate-100 reveal">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-km-serif font-bold text-onyx mb-4">រូបភាពមុខម្ហូបពិសេសៗ</h2>
            <p class="text-slate-600 font-km-sans tracking-widest">រូបភាពពិតៗពីកម្មវិធីដែលរៀបចំដោយក្រុមចុងភៅ CKM</p>
          </div>
          
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
            {menuImages.map((img, i) => (
              <div class="group relative aspect-square overflow-hidden rounded-sm bg-slate-100">
                <Image src={img} alt={altTexts[i] || `រូបភាពម្ហូបការ CKM ទី ${i + 1}`} class="w-full h-full object-cover transition-transform duration-[1500ms] group-hover:scale-105" loading="lazy" decoding="async" />
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="blog" class="py-20 bg-white border-t border-slate-100 reveal">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-km-serif font-bold text-onyx mb-4">អត្ថបទ និងចំណេះដឹង</h2>
            <p class="text-slate-600 font-km-sans tracking-widest">ស្វែងយល់បន្ថែមអំពីការរៀបចំកម្មវិធី និងបទពិសោធន៍របស់ CKM</p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {recentPosts.map(post => {
              const slug = post.id.replace(/\.mdx?$/, '');
              return (
                <a href={`/blog/${slug}/`} class="group block h-full">
                  <article class="bg-white rounded-sm border border-slate-100 shadow-sm hover:shadow-glow-lg hover:border-champagne/30 transition-all duration-500 overflow-hidden flex flex-col h-full">
                    {post.data.coverImage && (
                      <div class="w-full aspect-[16/9] overflow-hidden bg-slate-100">
                        <Image src={post.data.coverImage} alt={post.data.title} width={600} height={337} class="w-full h-full object-cover transition-transform duration-[1500ms] group-hover:scale-105" />
                      </div>
                    )}
                    <div class="p-6 md:p-8 flex flex-col flex-grow">
                      <h3 class="text-xl font-km-serif font-bold text-onyx group-hover:text-champagne-dark transition-colors duration-300 mb-4 line-clamp-2 leading-relaxed">{post.data.title}</h3>
                      <p class="text-slate-500 font-km-sans text-sm mb-6 line-clamp-3 leading-relaxed">{post.data.description}</p>
                      <div class="mt-auto text-champagne-dark font-bold font-km-sans flex items-center gap-2">
                        អានបន្ថែម <ChevronRight class="w-4 h-4" strokeWidth={2} />
                      </div>
                    </div>
                  </article>
                </a>
              );
            })}
          </div>
          
          <div class="text-center mt-12">
             <a href="/blog/" class="inline-flex items-center justify-center gap-2 bg-onyx hover:bg-slate-800 text-white px-8 py-4 rounded-sm font-km-sans font-medium transition-all shadow-md hover:shadow-lg">
               អត្ថបទទាំងអស់ <ChevronRight class="w-4 h-4" strokeWidth={1.5} />
             </a>
          </div>
        </div>
      </section>

      <section id="contact" class="py-20 bg-onyx relative border-t border-slate-800 reveal">
          <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
              <h2 class="text-3xl md:text-4xl font-km-serif font-bold text-white mb-6">ត្រូវការពិភាក្សាអំពីកម្មវិធីរបស់លោកអ្នក?</h2>
              <p class="text-slate-400 font-km-sans mb-10">
                  សូមទំនាក់ទំនងមកកាន់យើងខ្ញុំឥឡូវនេះ ដើម្បីទទួលបានការប្រឹក្សាយោបល់ និង <strong class="text-white font-medium">ពិភាក្សាពីថវិកា ឬ តម្លៃម្ហូបការ</strong> ដោយឥតគិតថ្លៃ។
              </p>
              
              <div class="bg-slate-900 p-8 rounded-sm inline-block w-full max-w-2xl text-left border border-slate-800 shadow-xl">
                  <div class="flex flex-col md:flex-row gap-8 items-center justify-between">
                      <div>
                          <p class="text-slate-500 font-km-sans text-sm mb-4">លេខទូរស័ព្ទទំនាក់ទំនង៖</p>
                          <div class="flex flex-col gap-3 mb-6">
                              {phoneNumbers.map((contact) => (
                                  <a href={`tel:+855${contact.num.replace(/\s/g, '').substring(1)}`} class="flex items-center gap-3 group">
                                      <div class="w-10 h-10 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center group-hover:border-champagne transition-colors text-slate-400 group-hover:text-champagne" set:html={contact.svg} />
                                      <div>
                                          <span class="text-lg font-bold text-white font-sans tracking-wider block leading-none group-hover:text-champagne-dark transition-colors">{contact.num}</span>
                                          <span class="text-xs text-slate-500 font-sans uppercase tracking-widest">{contact.type}</span>
                                      </div>
                                  </a>
                              ))}
                          </div>
                          <p class="text-slate-500 font-km-sans text-sm">ទីតាំង៖ ផ្ទះលេខ 33 ផ្លូវ 257 សង្កាត់ទឹកល្អក់ទី២ ខណ្ឌទួលគោក រាជធានីភ្នំពេញ</p>
                      </div>
                      
                      <div class="flex gap-4">
                          <a href={telegramLink} target="_blank" rel="noopener noreferrer" aria-label="ផ្ញើសារតាម Telegram" class="w-14 h-14 rounded-full bg-[#005f8f] hover:bg-[#004b73] flex items-center justify-center text-white transition-colors shadow-lg">
                              <Send class="w-6 h-6" strokeWidth={1.5} />
                          </a>
                          <a href={facebookLink} target="_blank" rel="noopener noreferrer" aria-label="ទំព័រ Facebook" class="w-14 h-14 rounded-full bg-[#1877F2] hover:bg-[#166FE5] flex items-center justify-center text-white transition-colors shadow-lg">
                              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                          </a>
                      </div>
                  </div>
              </div>
          </div>
      </section>
  </article>
</Layout>

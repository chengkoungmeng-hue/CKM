---
// src/pages/index.astro
// 狀態: 根節點高棉語實體 (Root Node Khmer Entity) & 轉換摩擦力歸零
import Layout from '../layouts/Layout.astro'; 

const siteDomain = "https://www.ckmkh.com";
const telegramLink = "https://t.me/CKMSam06";
const facebookLink = "https://www.facebook.com/CKMFOODS";

const heroImageRelative = "/images/home/hero-luxury-banquet-setup.webp";
const heroImageAbsolute = `${siteDomain}${heroImageRelative}`;
const logo = "/images/home/brand-ckm-logo-gold.webp";

const mainPhone = "011 827 782";
const phoneNumbers = [
  { num: "011 827 782", icon: "fa-mobile-alt", type: "Cellcard" },
  { num: "012 977 696", icon: "fa-phone", type: "Cellcard" },
  { num: "015 977 696", icon: "fa-phone-volume", type: "Smart" }
];

const menuItems = [
  { title: "ម្ហូបក្លែម៦មុខ", image: "/images/home/menu-01.webp", desc: "ការរួមបញ្ចូលគ្នានៃវាយនភាព និងសីតុណ្ហភាពខុសៗគ្នាទាំង៦មុខ ដើម្បីជម្រុញក្រពេញទឹកមាត់ និងរៀបចំប្រព័ន្ធរំលាយអាហារមុនពេលទទួលទានម្ហូបចម្បង។" },
  { title: "ត្រីដប៊ុនបំពងស្រួយ", image: "/images/home/menu-02.webp", desc: "អនុវត្តបច្ចេកទេសបំពងដោយសីតុណ្ហភាពប្រេងថេរ ដើម្បីបង្កើតសំបកក្រៅស្រួយ និងទប់ស្កាត់ការបាត់បង់ជាតិទឹក (Moisture retention) នៅក្នុងសាច់ត្រី។" },
  { title: "ភាសាច់គោក្រៅអង្គារ", image: "/images/home/menu-03.webp", desc: "សាច់គោចម្អិនក្នុងកម្រិតមធ្យម (Medium Rare) លាយជាមួយអាស៊ីតពីក្រូចឆ្មារ និងសារធាតុ Capsaicin ពីម្ទេស បង្កើតបានជាតុល្យភាពរសជាតិជូរហិរ។" },
  { title: "បង្កងបំពងគ្រាប់ធញ្ញជាតិ", image: "/images/home/menu-04.webp", desc: "បង្កងទន្លេបំពង រួមបញ្ចូលជាមួយគ្រាប់ធញ្ញជាតិលីង និងប៊័រ ដើម្បីទាញយកក្លិនក្រអូបតាមរយៈប្រតិកម្ម Maillard (Maillard reaction)។" },
  { title: "ជ្រូកខ្វៃនិងនំប៉័ង", image: "/images/home/menu-05.webp", desc: "ការចម្អិនដោយកម្តៅស្ងួត (Dry heat) ដើម្បីបំបែកជាតិខ្លាញ់ និងធ្វើឱ្យស្បែកស្រួយ ញ៉ាំផ្ទាប់ជាមួយនំប៉័ងទន់ បង្កើតនូវភាពផ្ទុយគ្នានៃវាយនភាព (Texture contrast)។" },
  { title: "ត្រីតុកកែជូរអែម", image: "/images/home/menu-06.webp", desc: "សាច់ត្រីបំពងស្រួយ គ្របដណ្តប់ដោយទឹកជ្រលក់ដែលមានកម្រិត pH តុល្យភាពរវាងជាតិជូរ និងផ្អែម ធានាបាននូវការស្រូបយករសជាតិស្មើគ្នា។" },
  { title: "ត្រីហឹរឡប់ពង", image: "/images/home/menu-07.webp", desc: "ប្រើប្រាស់បច្ចេកទេសឆាភ្លើងខ្លាំង (Wok hei) ក្នុងរយៈពេលខ្លី ដើម្បីទាញយកប្រេងសំខាន់ៗពីគ្រឿងទេស និងរក្សាភាពតឹងណែននៃសាច់ត្រី។" },
  { title: "ស៊ុបប៉ាវហឺ១០មុខ", image: "/images/home/menu-08.webp", desc: "ដំណើរការរម្ងាស់កម្តៅទាបរយៈពេលយូរ (Slow simmer) ដើម្បីបំបែកប្រូតេអ៊ីនខូឡាជែន និងស្រង់យកសារធាតុរ៉ែពីឱសថបុរាណចិនទាំង១០មុខ។" },
  { title: "ញាំជើងទាបង្គោរមិក", image: "/images/home/menu-09.webp", desc: "ជើងទាដកឆ្អឹងដោយរក្សានូវរចនាសម្ព័ន្ធសរសៃពួរ និងឆ្អឹងខ្ចី លាយជាមួយទឹកជ្រលក់ដែលមានជាតិអាស៊ីតខ្ពស់ ដើម្បីបន្សាបជាតិខាញ់។" },
  { title: "ត្រីតុកកែចំហ៊ុយទឹកស៊ីអ៊ីវ", image: "/images/home/menu-10.webp", desc: "ការចំហ៊ុយដោយគ្រប់គ្រងពេលវេលាយ៉ាងតឹងរ៉ឹង ដើម្បីទប់ស្កាត់ការកកិតប្រូតេអ៊ីនហួសកម្រិត (Over-coagulation) រក្សាបាននូវសាច់ត្រីទន់ និងរលោង។" },
  { title: "បាយខ្ទប់ស្លឹកឈូក", image: "/images/home/menu-11.webp", desc: "បាយចម្អិនតាមរយៈការចំហ៊ុយក្នុងបរិយាកាសបិទជិត ដើម្បីឱ្យម៉ូលេគុលក្លិនក្រអូបពីស្លឹកឈូកជ្រាបចូលទៅក្នុងគ្រាប់បាយនីមួយៗ។" },
  { title: "ទាខ្វៃហុងកុង", image: "/images/home/menu-12.webp", desc: "ឆ្លងកាត់ដំណើរការសម្ងួតស្បែកដោយខ្យល់ត្រជាក់ និងការខ្វៃក្នុងឡកម្តៅខ្ពស់ ដើម្បីរំលាយខ្លាញ់ក្រោមស្បែក និងធ្វើឱ្យស្បែកស្រួយ។" },
  { title: "បង្អែមខ្មែរបុរាណ", image: "/images/home/menu-13.webp", desc: "ការប្រើប្រាស់ជាតិខ្លាញ់រុក្ខជាតិពីខ្ទិះដូង លាយបញ្ជូលជាមួយក្លិនក្រអូបពីស្លឹកតើយ ដើរតួជាសារធាតុជួយសម្រួលប្រព័ន្ធរំលាយអាហារនៅចុងបញ្ចប់នៃអាហារ។" },
  { title: "តុងយាំបង្កងទន្លេ", image: "/images/home/menu-14.webp", desc: "រចនាសម្ព័ន្ធស៊ុបដែលមានមូលដ្ឋានលើអាស៊ីតស៊ីទ្រិច ផ្សំជាមួយប្រូតេអ៊ីនពីបង្កងទន្លេ បង្កើតបានជាទម្រង់រសជាតិ (Flavor profile) ដ៏ស្មុគស្មាញ។" },
  { title: "កូនជ្រូកខ្វៃទាំងមូល", image: "/images/home/menu-15.webp", desc: "បច្ចេកទេសខ្វៃសាច់ជ្រូកទាំងមូលដោយការបង្វិលជាបន្តបន្ទាប់ ដើម្បីចែកចាយកម្តៅស្មើគ្នា និងធ្វើឱ្យប្រតិកម្ម Maillard កើតឡើងលើផ្ទៃស្បែកទាំងអស់។" },
];

const blogPosts = [
  { title: "ម៉ាទ្រីសវាយតម្លៃសេវាកម្មម្ហូបការ", subTitle: "ការគណនាទំហំទីតាំង និងប្រសិទ្ធភាពចរាចរណ៍ការងារ", link: "/km/blog/01-venue-logistics/", image: "/images/home/blog-wedding-service-guide.webp" },
  { title: "ប្រព័ន្ធគ្រប់គ្រងសីតុណ្ហភាពខ្នាតធំ", subTitle: "បច្ចេកទេសទប់ស្កាត់ការបាត់បង់កម្តៅ និងរក្សាសំណើមអាហារ", link: "/km/blog/02-event-party-planning/", image: "/images/home/blog-event-party-planning.webp" },
  { title: "ខ្សែចង្វាក់ផ្គត់ផ្គង់ និងការគ្រប់គ្រងវត្ថុធាតុដើម", subTitle: "ការអនុវត្តខ្សែសង្វាក់ត្រជាក់ទប់ស្កាត់ប្រតិកម្មអុកស៊ីតកម្ម", link: "/km/blog/03-chef-professional-standard/", image: "/images/home/blog-chef-professional-standard.webp" },
  { title: "ពិធីសារសុវត្ថិភាពជីវសាស្រ្តអាហារ", subTitle: "បច្ចេកទេសកម្ចាត់ភ្នាក់ងារបង្កជំងឺតាមរយៈការគ្រប់គ្រងកម្តៅ", link: "/km/blog/04-food-safety-quality/", image: "/images/home/blog-food-safety-quality.webp" },
  { title: "រចនាសម្ព័ន្ធរសជាតិ និងជីវគីមីនៃអាហារ", subTitle: "សមាមាត្រនៃគ្រឿងទេសខ្មែរនិងបច្ចេកទេសចម្អិនបែបចិន", link: "/km/blog/05-khmer-wedding-menu/", image: "/images/home/blog-khmer-wedding-menu.webp" },
  { title: "ស្តង់ដារប្រតិបត្តិការ (SOP) និងការកាត់បន្ថយហានិភ័យ", subTitle: "ការរៀបចំប្រព័ន្ធការពារជាមុនដើម្បីអត្រាកំហុសស្មើសូន្យ", link: "/km/blog/06-service-process-sop/", image: "/images/home/blog-service-process-sop.webp" }
];
---
<Layout title="ចុងភៅ ចេង គួងម៉េង - CKM Premium Catering" description="CKM Catering ផ្តល់ជូននូវសេវាកម្មម្ហូបការ និងជប់លៀងលំដាប់ខ្ពស់ ដោយផ្តោតលើគុណភាព សុវត្ថិភាព និងភាពល្អឥតខ្ចោះ។" image={heroImageAbsolute} lang="km">
  <Fragment slot="head">
    <link rel="preload" as="image" href={heroImageRelative} />
    <link href="https://fonts.googleapis.com/css2?family=Hanuman:wght@400;700&family=Kantumruy+Pro:wght@300;400;500;600&display=swap" rel="stylesheet">
  </Fragment>

  <style>
    .font-km-serif { font-family: 'Hanuman', serif; }
    .font-km-sans { font-family: 'Kantumruy Pro', sans-serif; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>

  <div class="w-full">
      <header class="relative h-screen flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 bg-cover bg-center bg-no-repeat bg-fixed transform scale-105" style={`background-image: url('${heroImageRelative}');`}></div>
        <div class="absolute inset-0 bg-black/60 bg-gradient-to-b from-black/80 via-black/50 to-slate-900"></div>
        <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-10">
            <img src={logo} alt="CKM Logo" width="128" height="128" class="w-32 h-32 md:w-44 md:h-44 rounded-full border-4 border-amber-500 mx-auto mb-8 shadow-[0_0_40px_rgba(245,158,11,0.5)]">
            <h1 class="text-4xl md:text-6xl font-km-serif font-bold text-white mb-6 leading-tight">ចុងភៅ <span class="text-amber-500">ចេង គួងម៉េង</span></h1>
            <h2 class="text-xl md:text-2xl font-km-sans font-medium text-white/90 mb-6 uppercase">សេវាកម្មម្ហូបការលំដាប់ខ្ពស់នៅភ្នំពេញ</h2>
            <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-2xl mx-auto font-km-sans font-light leading-relaxed hidden sm:block">ធានាបាននូវការរៀបចំកម្មវិធីដ៏ល្អឥតខ្ចោះ សម្រាប់ពិធីមង្គលការ និងកម្មវិធីជប់លៀងខ្នាតធំ។</p>
            
            <div class="flex flex-row gap-3 justify-center animate-fade-in-up w-full max-w-sm mx-auto sm:max-w-none" style="animation-delay: 0.1s;">
                <a href={`tel:+855${mainPhone.replace(/\s/g, '').substring(1)}`} class="flex-1 sm:flex-none bg-amber-500 hover:bg-amber-600 text-slate-900 px-2 sm:px-8 py-3 sm:py-4 min-h-[48px] rounded-sm font-km-sans font-bold text-sm sm:text-base uppercase tracking-wider transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <i class="fas fa-phone-alt"></i> <span class="whitespace-nowrap">ហៅទូរស័ព្ទឥឡូវនេះ</span>
                </a>
                <a href={telegramLink} target="_blank" rel="noopener noreferrer" class="flex-1 sm:flex-none bg-[#0088cc] hover:bg-[#007ab8] text-white px-2 sm:px-8 py-3 sm:py-4 min-h-[48px] rounded-sm font-km-sans font-medium text-sm sm:text-base transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <i class="fab fa-telegram-plane text-lg"></i> <span class="whitespace-nowrap">ពិគ្រោះយោបល់</span>
                </a>
            </div>
        </div>
      </header>

      <section class="py-12 bg-amber-500 relative z-20 shadow-xl">
        <div class="max-w-7xl mx-auto px-6">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center divide-x divide-amber-600/30">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-5xl font-serif font-bold text-slate-950 mb-1 md:mb-2">៦០+</span>
              <span class="text-slate-800 text-xs md:text-sm font-sans font-medium uppercase tracking-wider">ឆ្នាំនៃកេរដំណែល</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <div class="h-[28px] md:h-[48px] flex items-center mb-1 md:mb-2">
                  <i class="fas fa-gem text-2xl md:text-4xl text-slate-950 opacity-90"></i>
              </div>
              <span class="text-slate-800 text-xs md:text-sm font-sans font-medium uppercase tracking-wider">គុណភាពលំដាប់កំពូល</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <div class="h-[28px] md:h-[48px] flex items-center mb-1 md:mb-2">
                  <i class="fas fa-concierge-bell text-2xl md:text-4xl text-slate-950 opacity-90"></i>
              </div>
              <span class="text-slate-800 text-xs md:text-sm font-sans font-medium uppercase tracking-wider">សិល្បៈធ្វើម្ហូបឯកទេស</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-5xl font-serif font-bold text-slate-950 mb-1 md:mb-2">១០០%</span>
              <span class="text-slate-800 text-xs md:text-sm font-sans font-medium uppercase tracking-wider">ទំនុកចិត្តនិងសុវត្ថិភាព</span>
            </div>
          </div>
        </div>
      </section>

      <section class="py-16 md:py-24 bg-slate-900 relative overflow-hidden">
         <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="text-center mb-12 md:mb-16"><h2 class="text-3xl md:text-4xl font-km-serif font-bold text-white">ស្តង់ដារប្រតិបត្តិការឥតខ្ចោះ</h2></div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                 <div class="bg-slate-800/50 p-8 md:p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-6 md:mb-8"><i class="fas fa-gem text-xl md:text-2xl text-amber-500"></i></div>
                    <h3 class="text-xl md:text-2xl font-km-serif font-bold text-white mb-3 md:mb-4">វត្ថុធាតុដើមគុណភាពកំពូល</h3>
                    <p class="text-gray-400 text-sm md:text-base font-km-sans font-light leading-relaxed">ការជ្រើសរើសគ្រឿងផ្សំស្រស់ៗបំផុតពីប្រភពដើម ដោយរក្សាបាននូវរសជាតិធម្មជាតិពិតៗ ដើម្បីផ្តល់ជូននូវបទពិសោធន៍ម្ហូបអាហារដ៏ឧត្តុង្គឧត្តម។</p>
                 </div>
                 <div class="bg-slate-800/50 p-8 md:p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-6 md:mb-8"><i class="fas fa-project-diagram text-xl md:text-2xl text-amber-500"></i></div>
                    <h3 class="text-xl md:text-2xl font-km-serif font-bold text-white mb-3 md:mb-4">ការគ្រប់គ្រងកម្មវិធីខ្នាតធំ</h3>
                    <p class="text-gray-400 text-sm md:text-base font-km-sans font-light leading-relaxed">សមត្ថភាពរៀបចំម្ហូបសម្រាប់ភ្ញៀវរាប់ពាន់នាក់ ដោយរក្សាបាននូវរសជាតិ និងសីតុណ្ហភាពស្តង់ដារដូចគ្នាពីតុដំបូងរហូតដល់តូចុងក្រោយ។</p>
                 </div>
                 <div class="bg-slate-800/50 p-8 md:p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-6 md:mb-8"><i class="fas fa-shield-alt text-xl md:text-2xl text-amber-500"></i></div>
                    <h3 class="text-xl md:text-2xl font-km-serif font-bold text-white mb-3 md:mb-4">ស្តង់ដារអនាម័យវេជ្ជសាស្ត្រ</h3>
                    <p class="text-gray-400 text-sm md:text-base font-km-sans font-light leading-relaxed">អនុវត្តយ៉ាងតឹងរ៉ឹងនូវការបំបែកម្ហូបឆៅនិងឆ្អិន ព្រមទាំងធានាសីតុណ្ហភាពចម្អិនលើសពី 75°C ដើម្បីសុវត្ថិភាពសុខភាពជាដាច់ខាត។</p>
                 </div>
            </div>
         </div>
      </section>

      <section class="py-16 md:py-24 bg-white overflow-hidden">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-10 md:mb-16"><h2 class="text-3xl md:text-4xl font-km-serif font-bold text-slate-900">កំពូលស្នាដៃម្ហូបឯក</h2></div>
          
          <div class="flex overflow-x-auto md:grid md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8 pb-6 -mx-6 px-6 md:mx-0 md:px-0 snap-x snap-mandatory scrollbar-hide">
            {menuItems.map((item) => (
                <div class="group relative overflow-hidden rounded-sm shadow-md bg-slate-50 flex-none w-[80%] sm:w-[50%] md:w-auto snap-center snap-always">
                    <div class="aspect-square overflow-hidden relative bg-slate-200">
                      <img src={item.image} alt={item.title} width="600" height="600" decoding="async" loading="lazy" class="w-full h-full object-cover transform group-hover:scale-105 transition duration-700"/>
                      <div class="absolute inset-0 bg-gradient-to-t from-slate-900/95 via-slate-900/30 to-transparent opacity-85 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    <div class="absolute inset-0 flex flex-col justify-end p-5 md:p-8 pointer-events-none">
                      <h3 class="text-lg md:text-xl font-km-serif font-bold text-amber-400 mb-2 md:mb-3 md:translate-y-4 md:group-hover:translate-y-0 transition duration-500">{item.title}</h3>
                      <p class="text-gray-200 text-xs md:text-sm font-km-sans font-light leading-relaxed md:opacity-0 md:group-hover:opacity-100 transform md:translate-y-4 md:group-hover:translate-y-0 transition-all duration-500 delay-100 line-clamp-3 md:line-clamp-none">{item.desc}</p>
                    </div>
                </div>
            ))}
          </div>
        </div>
      </section>

      <section class="py-16 md:py-24 bg-slate-50 border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-6">
           <div class="text-center mb-10 md:mb-16"><h2 class="text-3xl md:text-4xl font-km-serif font-bold text-slate-900">ទស្សនៈ និងការវិភាគកម្រិតកំពូល</h2></div>
           <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
              {blogPosts.map(post => (
                <div class="group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-500 border border-slate-100 flex flex-col">
                   <a href={post.link} class="block aspect-[16/9] overflow-hidden relative bg-slate-200">
                      <img src={post.image} alt={post.title} width="600" height="337" decoding="async" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition duration-700"/>
                   </a>
                   <div class="p-6 md:p-8 flex flex-col flex-grow">
                      <h3 class="text-lg md:text-xl font-km-serif font-bold text-slate-900 mb-2 md:mb-3 group-hover:text-amber-600 transition-colors duration-300 leading-snug">{post.title}</h3>
                      <p class="text-slate-500 text-xs md:text-sm font-km-sans font-light mb-4 md:mb-6 leading-relaxed">{post.subTitle}</p>
                      <a href={post.link} class="mt-auto inline-flex items-center text-amber-600 text-xs md:text-sm font-km-sans font-medium hover:text-amber-700 transition-colors">ស្វែងយល់បន្ថែម <i class="fas fa-arrow-right ml-2"></i></a>
                   </div>
                </div>
              ))}
           </div>
        </div>
      </section>

      <section id="contact" class="relative py-20 md:py-32 bg-slate-950 border-t border-slate-800 overflow-hidden">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-[1px] bg-gradient-to-r from-transparent via-amber-500/30 to-transparent"></div>
          
          <div class="max-w-7xl mx-auto px-6 relative z-10">
              <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-16 lg:gap-8 items-center">
                  <div class="lg:col-span-5 text-left text-center lg:text-left">
                      <div class="inline-flex items-center gap-4 mb-6 md:mb-8">
                          <span class="w-8 md:w-12 h-[1px] bg-amber-500"></span>
                          <span class="text-amber-500 text-[10px] md:text-xs font-km-sans font-medium uppercase">ទំនាក់ទំនងផ្ទាល់</span>
                          <span class="w-8 h-[1px] bg-amber-500 lg:hidden"></span>
                      </div>
                      <h2 class="text-3xl md:text-4xl lg:text-5xl font-km-serif font-bold text-white mb-6 md:mb-8 leading-tight">ពិគ្រោះយោបល់កម្រិតខ្ពស់</h2>
                      <p class="text-slate-400 text-sm md:text-lg font-km-sans font-light leading-relaxed mb-8 md:mb-10 max-w-md mx-auto lg:mx-0">
                          កម្មវិធីដ៏ល្អឥតខ្ចោះមួយ ចាប់ផ្តើមពីការពិភាក្សាផ្អែកលើទិន្នន័យជាក់ស្តែង និងការវាយតម្លៃហេដ្ឋារចនាសម្ព័ន្ធយ៉ាងច្បាស់លាស់។
                      </p>
                  </div>

                  <div class="lg:col-span-7 lg:col-start-6">
                      <div class="bg-slate-900 border border-slate-800 p-6 md:p-12 rounded-sm shadow-2xl">
                          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4 mb-6 md:mb-10">
                              {phoneNumbers.map((contact) => (
                                  <a href={`tel:+855${contact.num.replace(/\s/g, '').substring(1)}`} class="group flex items-center p-4 md:p-6 rounded-sm bg-slate-950 border border-slate-800 hover:border-amber-500/50 transition-colors duration-300 min-h-[64px] md:min-h-[88px]">
                                      <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-900 flex items-center justify-center shrink-0 mr-4 group-hover:bg-amber-500/10 transition-colors">
                                        <i class={`fas ${contact.icon} text-amber-500 text-sm md:text-xl`}></i>
                                      </div>
                                      <div>
                                        <div class="text-white font-serif font-semibold text-base md:text-lg tracking-wide">{contact.num}</div>
                                        <div class="text-slate-500 text-[10px] md:text-xs font-sans uppercase mt-0.5 md:mt-1">{contact.type}</div>
                                      </div>
                                  </a>
                              ))}
                              
                              <div class="flex items-center gap-3 md:gap-4 p-4 md:p-6 rounded-sm bg-slate-950 border border-slate-800 min-h-[64px] md:min-h-[88px]">
                                  <a href={telegramLink} target="_blank" rel="noopener noreferrer" aria-label="Telegram" class="flex-1 h-10 md:h-12 rounded-sm bg-[#0088cc] hover:bg-[#007ab8] flex items-center justify-center text-white transition-colors duration-300">
                                      <i class="fab fa-telegram-plane text-base md:text-xl"></i>
                                  </a>
                                  <a href={facebookLink} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex-1 h-10 md:h-12 rounded-sm bg-[#1877F2] hover:bg-[#166FE5] flex items-center justify-center text-white transition-colors duration-300">
                                      <i class="fab fa-facebook-f text-base md:text-xl"></i>
                                  </a>
                              </div>
                          </div>
                          
                          <div class="pt-6 md:pt-8 border-t border-slate-800">
                              <div class="flex items-start gap-4 md:gap-6">
                                  <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-950 border border-slate-800 flex items-center justify-center shrink-0">
                                      <i class="fas fa-map-marker-alt text-amber-500 text-sm md:text-base"></i>
                                  </div>
                                  <div>
                                      <h4 class="text-white font-km-sans font-medium text-sm md:text-sm mb-1.5 md:mb-2">ទីស្នាក់ការកណ្តាល</h4>
                                      <p class="text-slate-400 text-xs md:text-sm font-km-sans font-light leading-relaxed">
                                          ផ្ទះលេខ 33 ផ្លូវ 257 សង្កាត់ទឹកល្អក់ទី២<br class="hidden sm:block"/>ខណ្ឌទួលគោក រាជធានីភ្នំពេញ
                                      </p>
                                  </div>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>
          </div>
      </section>

      <footer class="bg-slate-950 py-8 md:py-10 border-t border-slate-900 text-center font-km-sans">
          <p class="text-slate-600 text-[10px] md:text-xs font-light">&copy; 2026 CKM Catering Service. រក្សាសិទ្ធិគ្រប់យ៉ាង។</p>
      </footer>
  </div>
</Layout>
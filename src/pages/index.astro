<Layout title="ចុងភៅ ចេង គួងម៉េង - CKM Premium Catering & Event Infrastructure" description="សេវាកម្មម្ហូបការ ជួលរោងការ និងហេដ្ឋារចនាសម្ព័ន្ធកម្មវិធីខ្នាតធំនៅភ្នំពេញ។ ទទួលបានការគាំទ្រពីអតិថិជនជាង ១ម៉ឺននាក់ ជាមួយនឹងប្រតិបត្តិការភស្តុភារ ២៤ម៉ោង។" lang="km-KH">
  <Fragment slot="head">
    <link rel="preload" as="image" href={heroImageRelative} fetchpriority="high" />
    
    <link href="https://fonts.googleapis.com/css2?family=Hanuman:wght@400;700&family=Kantumruy+Pro:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FoodEstablishment",
      "name": "CKM Premium Catering (ចុងភៅ ចេង គួងម៉េង)",
      "image": "https://www.ckmkh.com/images/home/brand-ckm-logo-gold.webp",
      "description": "សេវាកម្មម្ហូបការលំដាប់កំពូល ជួលរោងការ និងហេដ្ឋារចនាសម្ព័ន្ធកម្មវិធីខ្នាតធំនៅភ្នំពេញ។",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "ផ្ទះលេខ 33 ផ្លូវ 257 សង្កាត់ទឹកល្អក់ទី២ ខណ្ឌទួលគោក",
        "addressLocality": "Phnom Penh",
        "addressRegion": "Phnom Penh",
        "addressCountry": "KH"
      },
      "telephone": "+85511827782",
      "url": "https://www.ckmkh.com/",
      "servesCuisine": ["Khmer Cuisine", "Chinese Banquet"],
      "priceRange": "$$$$",
      "sameAs": [
        "https://www.facebook.com/CKMFOODS",
        "https://t.me/CKMSam06"
      ]
    })} />
  </Fragment>

  <style>
    .font-km-serif { font-family: 'Hanuman', serif; }
    .font-km-sans { font-family: 'Kantumruy Pro', sans-serif; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>

  <div class="w-full">
      <header class="relative h-screen flex items-center justify-center overflow-hidden">
        <Image src={heroImageRelative} alt="CKM Luxury Banquet Setup" width={1920} height={1080} class="absolute inset-0 w-full h-full object-cover object-center transform scale-105" fetchpriority="high" loading="eager" decoding="sync" />
        <div class="absolute inset-0 bg-black/70 bg-gradient-to-b from-black/80 via-black/50 to-slate-900/90"></div>
        
        <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-10">
            <Image src={logo} alt="CKM Logo" width={176} height={176} class="w-32 h-32 md:w-44 md:h-44 rounded-full border-4 border-amber-500 mx-auto mb-8 shadow-[0_0_40px_rgba(245,158,11,0.5)]" />
            <h1 class="text-4xl md:text-6xl font-km-serif font-bold text-white mb-6 leading-tight">ចុងភៅ <span class="text-amber-500">ចេង គួងម៉េង</span></h1>
            <h2 class="text-xl md:text-2xl font-km-sans font-medium text-white/90 mb-6 uppercase">សេវាកម្មម្ហូបការ និងហេដ្ឋារចនាសម្ព័ន្ធលំដាប់កំពូល</h2>
            <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-3xl mx-auto font-km-sans font-light leading-relaxed hidden sm:block">ជាង ៦ ទសវត្សរ៍នៃកិត្តិនាម ទទួលបានការគាំទ្រពីអតិថិជនជាង ១ម៉ឺននាក់។ យើងជាក្រុមការងារអាជីព ផ្តល់សេវាកម្មជួលរោងការ និងរៀបចំម្ហូបការខ្នាតធំដោយគ្មានហានិភ័យ។</p>
            
            <div class="flex flex-row gap-3 justify-center animate-fade-in-up w-full max-w-sm mx-auto sm:max-w-none" style="animation-delay: 0.1s;">

---
// 實體路徑: src/pages/en/index.astro
import Layout from '../../layouts/Layout.astro'; 

const telegramLink = "https://t.me/CKMSam06";
const facebookLink = "https://www.facebook.com/CKMFOODS";
const heroImage = "/images/home/hero-luxury-banquet-setup.webp";
const logo = "/images/home/brand-ckm-logo-gold.webp";

const phoneNumbers = [
  { num: "011 827 782", icon: "fa-mobile-alt", type: "Cellcard" },
  { num: "012 977 696", icon: "fa-phone", type: "Cellcard" },
  { num: "015 977 696", icon: "fa-phone-volume", type: "Smart" }
];

const menuItems = [
  { title: "Assorted Premium Appetizers", image: "/images/home/menu-01.webp", desc: "A curated symphony of six premium appetizers designed to awaken the palate." },
  { title: "Deep-Fried Fish Fillet", image: "/images/home/menu-02.webp", desc: "Flash-fried at precise temperatures to achieve a golden crust while retaining oceanic moisture." },
  { title: "Authentic Khmer Beef Salad", image: "/images/home/menu-03.webp", desc: "A masterclass in balance, pairing tender beef with vibrant, citrus-infused Khmer spices." },
  { title: "Cereal Butter Prawns", image: "/images/home/menu-04.webp", desc: "Plump, wild-caught prawns coated in crispy cereal flakes and rich, aromatic butter." },
  { title: "Roasted Suckling Pig with Bread", image: "/images/home/menu-05.webp", desc: "Meticulously roasted for a glass-like crackling skin, served with soft bread for textural contrast." },
  { title: "Sweet & Sour Fish", image: "/images/home/menu-06.webp", desc: "Expertly carved deep-sea fish draped in an impeccably balanced sweet and sour glaze." },
  { title: "Spicy Stir-Fried Fish Fillet", image: "/images/home/menu-07.webp", desc: "Wok-tossed over extreme heat to impart a smoky essence and a burst of fiery aromatics." },
  { title: "Premium Abalone Herb Broth", image: "/images/home/menu-08.webp", desc: "A restorative elixir slow-simmered for hours, extracting the deep essence of abalone and herbs." },
  { title: "Spicy Duck Feet Salad", image: "/images/home/menu-09.webp", desc: "De-boned duck feet offering a crisp texture, tossed in a sharp, refreshing vinaigrette." },
  { title: "Steamed Fish with Premium Soy", image: "/images/home/menu-10.webp", desc: "Steamed to exact seconds to preserve delicate protein structures, finished with superior soy sauce." },
  { title: "Lotus Leaf Wrapped Fragrant Rice", image: "/images/home/menu-11.webp", desc: "Long-grain rice wok-fried and steamed within a lotus leaf, absorbing deep, earthy aromas." },
  { title: "Hong Kong Style Roast Duck", image: "/images/home/menu-12.webp", desc: "Traditional open-oven roasting renders the fat perfectly, resulting in crisp skin and succulent meat." },
  { title: "Royal Khmer Desserts", image: "/images/home/menu-13.webp", desc: "An elegant conclusion featuring the natural sweetness of fresh coconut milk and pandan." },
  { title: "Tom Yum River Prawn Soup", image: "/images/home/menu-14.webp", desc: "An intensely aromatic, spicy and sour broth featuring firm, wild-caught river prawns." },
  { title: "Signature Whole Roasted Pig", image: "/images/home/menu-15.webp", desc: "The centerpiece of high-end banquets, showcasing flawless roasting technique and prestige." },
];

const blogPosts = [
  { title: "Venue Logistics & Due Diligence", subTitle: "Site Audit & Execution Limits", link: "/en/blog/01-venue-logistics/", image: "/images/home/blog-wedding-service-guide.webp" },
  { title: "Throughput Control Matrix", subTitle: "Thermodynamics in Catering", link: "/en/blog/02-event-party-planning/", image: "/images/home/blog-event-party-planning.webp" },
  { title: "Supply Chain Defense Protocols", subTitle: "Yield Control & Sourcing", link: "/en/blog/03-chef-professional-standard/", image: "/images/home/blog-chef-professional-standard.webp" },
  { title: "Medical-Grade Food Safety", subTitle: "Core Temp & Isolation Rules", link: "/en/blog/04-food-safety-quality/", image: "/images/home/blog-food-safety-quality.webp" },
  { title: "Cross-Cultural Menu Engineering", subTitle: "Precision Flavor Architecture", link: "/en/blog/05-khmer-wedding-menu/", image: "/images/home/blog-khmer-wedding-menu.webp" },
  { title: "T-Minus Deployment SOP", subTitle: "Crisis Management & Tolerance", link: "/en/blog/06-service-process-sop/", image: "/images/home/blog-service-process-sop.webp" }
];
---
<Layout title="Chef Cheng Kuongmeng (钟光明) - CKM Premium Catering" description="CKM provides zero-error, high-end catering in Phnom Penh. Strict adherence to food safety protocols, unbroken cold chains, and logistical precision." image={heroImage} lang="en">
  <Fragment slot="head">
    <link rel="preload" as="image" href={heroImage} />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  </Fragment>

  <style>
    .font-luxury-serif { font-family: 'Playfair Display', serif; }
  </style>

  <header class="relative h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat bg-fixed transform scale-105" style={`background-image: url('${heroImage}');`}></div>
    <div class="absolute inset-0 bg-black/60 bg-gradient-to-b from-black/80 via-black/50 to-slate-900"></div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-10">
        <img src={logo} alt="CKM Logo" width="128" height="128" class="w-32 h-32 md:w-44 md:h-44 rounded-full border-4 border-amber-500 mx-auto mb-8 shadow-[0_0_40px_rgba(245,158,11,0.5)]">
        <h1 class="text-4xl md:text-6xl font-luxury-serif font-bold text-white mb-4 tracking-wide">Chef <span class="text-amber-500">Cheng Kuongmeng</span></h1>
        <h2 class="text-lg md:text-xl font-sans font-light text-white/90 mb-6 tracking-[0.2em] uppercase">Premier Catering Service</h2>
        <p class="text-lg md:text-xl text-gray-300 mb-10 max-w-2xl mx-auto font-sans font-light leading-relaxed">Uncompromising execution for high-end corporate banquets and premium weddings in Phnom Penh.</p>
        <div class="flex flex-col sm:flex-row gap-5 justify-center animate-fade-in-up" style="animation-delay: 0.1s;">
            <a href={telegramLink} target="_blank" class="bg-[#0077b5] hover:bg-[#005e93] text-white px-10 py-4 rounded-sm font-sans font-medium tracking-wider uppercase transition flex items-center gap-3">
                <i class="fab fa-telegram-plane text-2xl"></i> <span>Private Inquiry</span>
            </a>
        </div>
    </div>
  </header>

  <section class="py-24 bg-slate-900 relative overflow-hidden">
     <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16"><h2 class="text-3xl md:text-4xl font-luxury-serif font-bold text-white tracking-wide">The Execution Matrix</h2></div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
             <div class="bg-slate-800/50 p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                <div class="w-16 h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-8"><i class="fas fa-gem text-2xl text-amber-500"></i></div>
                <h3 class="text-2xl font-luxury-serif font-semibold text-white mb-4 tracking-wide">Uncompromised Sourcing</h3>
                <p class="text-gray-400 font-sans font-light leading-relaxed">Rigorous cold-chain logistics bridging the gap between origin and table. We lock in the absolute freshness of premium ingredients, refusing any degradation in quality.</p>
             </div>
             <div class="bg-slate-800/50 p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                <div class="w-16 h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-8"><i class="fas fa-project-diagram text-2xl text-amber-500"></i></div>
                <h3 class="text-2xl font-luxury-serif font-semibold text-white mb-4 tracking-wide">Flawless Orchestration</h3>
                <p class="text-gray-400 font-sans font-light leading-relaxed">From the first table to the thousandth guest, we guarantee the optimal serving temperature and texture, conquering the complexities of massive throughput.</p>
             </div>
             <div class="bg-slate-800/50 p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                <div class="w-16 h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-8"><i class="fas fa-shield-alt text-2xl text-amber-500"></i></div>
                <h3 class="text-2xl font-luxury-serif font-semibold text-white mb-4 tracking-wide">Medical-Grade Safety</h3>
                <p class="text-gray-400 font-sans font-light leading-relaxed">Absolute physical isolation between raw and cooked preparations. Every hot dish surpasses the 75°C bactericidal threshold, utilizing hard data to secure well-being.</p>
             </div>
        </div>
     </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16"><h2 class="text-3xl md:text-4xl font-luxury-serif font-bold text-slate-900 tracking-wide">Signature Masterpieces</h2></div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {menuItems.map((item) => (
            <div class="group relative overflow-hidden rounded-sm shadow-md bg-slate-50">
                <div class="aspect-square overflow-hidden relative">
                  <img src={item.image} alt={item.title} class="w-full h-full object-cover transform group-hover:scale-105 transition duration-700" loading="lazy"/>
                  <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/20 to-transparent opacity-80 group-hover:opacity-95 transition-opacity duration-500"></div>
                </div>
                <div class="absolute inset-0 flex flex-col justify-end p-8">
                  <h3 class="text-xl font-luxury-serif font-semibold text-amber-400 mb-3 translate-y-4 group-hover:translate-y-0 transition duration-500">{item.title}</h3>
                  <p class="text-gray-300 text-sm font-sans font-light leading-relaxed opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500 delay-100">{item.desc}</p>
                </div>
            </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-slate-50 border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-6">
       <div class="text-center mb-16"><h2 class="text-3xl md:text-4xl font-luxury-serif font-bold text-slate-900 tracking-wide">Premium Catering Insights</h2></div>
       <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {blogPosts.map(post => (
            <div class="group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-500 border border-slate-100 flex flex-col">
               <a href={post.link} class="block aspect-[16/9] overflow-hidden relative">
                  <img src={post.image} alt={post.title} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition duration-700"/>
               </a>
               <div class="p-8 flex flex-col flex-grow">
                  <h3 class="text-xl font-luxury-serif font-semibold text-slate-900 mb-3 group-hover:text-amber-600 transition-colors duration-300 leading-snug">{post.title}</h3>
                  <p class="text-slate-500 text-sm font-sans font-light mb-6">{post.subTitle}</p>
                  <a href={post.link} class="mt-auto inline-flex items-center text-amber-600 text-xs font-sans font-medium uppercase tracking-widest hover:text-amber-700 transition-colors">Explore <i class="fas fa-arrow-right ml-2"></i></a>
               </div>
            </div>
          ))}
       </div>
    </div>
  </section>

  <section id="contact" class="relative py-32 bg-slate-950 border-t border-slate-800 overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-[1px] bg-gradient-to-r from-transparent via-amber-500/30 to-transparent"></div>
      
      <div class="max-w-7xl mx-auto px-6 relative z-10">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8 items-center">
              <div class="lg:col-span-5 text-left">
                  <div class="inline-flex items-center gap-4 mb-8">
                      <span class="w-12 h-[1px] bg-amber-500"></span>
                      <span class="text-amber-500 text-xs font-sans font-medium tracking-[0.2em] uppercase">Private Consultation</span>
                  </div>
                  <h2 class="text-4xl md:text-5xl font-luxury-serif font-bold text-white mb-8 leading-tight">Initialize Protocol</h2>
                  <p class="text-slate-400 text-lg font-sans font-light leading-relaxed mb-10">
                      A flawless premium banquet begins with a rigorous consultation based on objective data and infrastructure assessment.
                  </p>
              </div>

              <div class="lg:col-span-6 lg:col-start-7">
                  <div class="bg-slate-900 border border-slate-800 p-8 md:p-12 rounded-sm shadow-2xl">
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">
                          {phoneNumbers.map((contact) => (
                              <a href={`tel:+855${contact.num.replace(/\s/g, '').substring(1)}`} class="group flex flex-col p-8 rounded-sm bg-slate-950 border border-slate-800 hover:border-amber-500/50 transition-colors duration-500">
                                  <i class={`fas ${contact.icon} text-amber-500 mb-5 text-2xl opacity-80 group-hover:opacity-100 transition-opacity`}></i>
                                  <span class="text-white font-luxury-serif font-semibold text-2xl tracking-wide mb-2">{contact.num}</span>
                                  <span class="text-slate-500 text-xs font-sans tracking-[0.2em] uppercase">{contact.type}</span>
                              </a>
                          ))}
                          <div class="flex items-center justify-center gap-6 p-8 rounded-sm bg-slate-950 border border-slate-800">
                              <a href={telegramLink} target="_blank" aria-label="Telegram" class="w-14 h-14 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-amber-500 hover:text-slate-950 hover:border-amber-500 transition-all duration-500">
                                  <i class="fab fa-telegram-plane text-xl"></i>
                              </a>
                              <a href={facebookLink} target="_blank" aria-label="Facebook" class="w-14 h-14 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-amber-500 hover:text-slate-950 hover:border-amber-500 transition-all duration-500">
                                  <i class="fab fa-facebook-f text-xl"></i>
                              </a>
                          </div>
                      </div>
                      <div class="pt-8 border-t border-slate-800">
                          <div class="flex items-start gap-6">
                              <div class="w-12 h-12 rounded-full bg-slate-950 border border-slate-800 flex items-center justify-center shrink-0">
                                  <i class="fas fa-map-marker-alt text-amber-500"></i>
                              </div>
                              <div>
                                  <h4 class="text-white font-sans font-medium text-xs tracking-[0.2em] uppercase mb-3">Headquarters</h4>
                                  <p class="text-slate-400 text-sm font-sans font-light leading-relaxed">
                                      House 33, St. 257, Sangkat Tuek Laak 2<br/>Toul Kork, Phnom Penh
                                  </p>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <footer class="bg-slate-950 py-10 border-t border-slate-900 text-center font-sans">
      <p class="text-slate-600 text-xs font-light tracking-[0.2em] uppercase">&copy; 2026 CKM Catering Service. All Rights Reserved.</p>
  </footer>
</Layout>
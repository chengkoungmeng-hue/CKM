---
// src/pages/en/index.astro
// Status: Copy optimized for operational realism, catering logistics, and execution.
import Layout from '../../layouts/Layout.astro'; 

const siteDomain = "https://www.ckmkh.com";
const telegramLink = "https://t.me/CKMSam06";
const facebookLink = "https://www.facebook.com/CKMFOODS";

const heroImageRelative = "/images/home/hero-luxury-banquet-setup.webp";
const logo = "/images/home/brand-ckm-logo-gold.webp";

// 提取主號碼供按鈕使用
const mainPhone = "011 827 782";
const phoneNumbers = [
  { num: "011 827 782", icon: "fa-mobile-alt", type: "Cellcard" },
  { num: "012 977 696", icon: "fa-phone", type: "Cellcard" },
  { num: "015 977 696", icon: "fa-phone-volume", type: "Smart" }
];

const menuItems = [
  { title: "Assorted Appetizer Platter", image: "/images/home/menu-01.webp", desc: "Six classic cold starters, portioned and temperature-controlled to begin the service efficiently without overwhelming the palate." },
  { title: "Deep-Fried Fish Fillet", image: "/images/home/menu-02.webp", desc: "Batch-fried at exact temperatures to maintain a crispy exterior and preserve internal moisture during high-volume service." },
  { title: "Khmer Style Beef Salad", image: "/images/home/menu-03.webp", desc: "Freshly prepared with authentic Khmer spices, providing a high-acid, refreshing contrast to heavy banquet proteins." },
  { title: "Cereal Butter Prawns", image: "/images/home/menu-04.webp", desc: "Wild-caught prawns wok-tossed in butter and cereal flakes, utilizing high heat for rapid execution and flavor." },
  { title: "Roasted Suckling Pig with Bread", image: "/images/home/menu-05.webp", desc: "Traditional suckling pig roasted with strict temperature control to ensure a consistent crispy skin, served with soft bread." },
  { title: "Sweet & Sour Fish", image: "/images/home/menu-06.webp", desc: "Crispy fried whole fish coated in a standardized sweet and sour glaze, engineered to hold its texture during transit." },
  { title: "Spicy Stir-Fried Fish Fillet", image: "/images/home/menu-07.webp", desc: "High-heat wok execution to seal the fish quickly and infuse consistent, fiery aromatics across every batch." },
  { title: "Abalone Herb Broth", image: "/images/home/menu-08.webp", desc: "Slow-simmered in large batches using precise ratios of abalone and herbs to ensure a consistent, temperature-stable hot soup." },
  { title: "Spicy Duck Feet Salad", image: "/images/home/menu-09.webp", desc: "Hand-deboned duck feet prepared under strict hygiene controls, tossed in a sharp vinaigrette for a clean palate reset." },
  { title: "Steamed Fish with Premium Soy", image: "/images/home/menu-10.webp", desc: "Steamed on a strict timer to prevent overcooking, served with a standardized soy sauce base." },
  { title: "Lotus Leaf Fragrant Rice", image: "/images/home/menu-11.webp", desc: "Wok-fried rice steamed in lotus leaves, a reliable carbohydrate staple that holds heat exceptionally well during service." },
  { title: "Hong Kong Style Roast Duck", image: "/images/home/menu-12.webp", desc: "Batch-roasted using traditional techniques to render fat evenly, ensuring the meat stays moist until plated." },
  { title: "Traditional Khmer Desserts", image: "/images/home/menu-13.webp", desc: "Fresh coconut milk and pandan prepared with strict sanitation protocols to securely close the meal." },
  { title: "Tom Yum River Prawn Soup", image: "/images/home/menu-14.webp", desc: "A robust, high-acid soup base that retains its heat and flavor profile perfectly from the kitchen to the table." },
  { title: "Signature Whole Roasted Pig", image: "/images/home/menu-15.webp", desc: "The centerpiece of large banquets, requiring exact timing and heat management to deliver a crispy, uniform finish." },
];

const blogPosts = [
  { title: "Venue Audits & Logistics", subTitle: "Electrical Loads & Setup Constraints", link: "/en/blog/01-venue-logistics/", image: "/images/home/blog-wedding-service-guide.webp" },
  { title: "100-Table Capacity Control", subTitle: "Managing Heat Loss & Service Flow", link: "/en/blog/02-event-party-planning/", image: "/images/home/blog-event-party-planning.webp" },
  { title: "Sourcing & Cold Chain", subTitle: "Ingredient Preservation & Batch Consistency", link: "/en/blog/03-chef-professional-standard/", image: "/images/home/blog-chef-professional-standard.webp" },
  { title: "Catering Food Safety", subTitle: "Cross-Contamination & The 75°C Kill Step", link: "/en/blog/04-food-safety-quality/", image: "/images/home/blog-food-safety-quality.webp" },
  { title: "Khmer-Chinese Menus", subTitle: "Flavor Sequencing & Palate Fatigue", link: "/en/blog/05-khmer-wedding-menu/", image: "/images/home/blog-khmer-wedding-menu.webp" },
  { title: "Execution & Contingency", subTitle: "T-Minus Schedules & Power Outages", link: "/en/blog/06-service-process-sop/", image: "/images/home/blog-service-process-sop.webp" }
];
---
<Layout title="Chef Cheng Koung Meng - CKM Professional Catering" description="CKM provides precision-driven, high-volume catering in Phnom Penh. Strict adherence to food safety protocols, unbroken cold chains, and logistical execution." lang="en">
  <Fragment slot="head">
    <link rel="preload" as="image" href={heroImageRelative} />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  </Fragment>

  <style>
    .font-luxury-serif { font-family: 'Playfair Display', serif; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>

  <div class="w-full">
      <header class="relative h-screen flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 bg-cover bg-center bg-no-repeat bg-fixed transform scale-105" style={`background-image: url('${heroImageRelative}');`}></div>
        <div class="absolute inset-0 bg-black/70 bg-gradient-to-b from-black/80 via-black/50 to-slate-900/90"></div>
        
        <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-10">
            <img src={logo} alt="CKM Logo" width="128" height="128" class="w-32 h-32 md:w-44 md:h-44 rounded-full border-4 border-amber-500 mx-auto mb-8 shadow-[0_0_40px_rgba(245,158,11,0.5)]">
            <h1 class="text-4xl md:text-6xl font-luxury-serif font-bold text-white mb-4 tracking-wide">Chef <span class="text-amber-500">Cheng Koung Meng</span></h1>
            <h2 class="text-lg md:text-xl font-sans font-light text-white/90 mb-6 tracking-[0.2em] uppercase">Professional Banquet Catering</h2>
            <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-2xl mx-auto font-sans font-light leading-relaxed hidden sm:block">Precision-driven catering and logistics for large-scale corporate banquets and weddings in Phnom Penh.</p>
            
            <div class="flex flex-row gap-3 justify-center animate-fade-in-up w-full max-w-sm mx-auto sm:max-w-none" style="animation-delay: 0.1s;">
                <a href={`tel:+855${mainPhone.replace(/\s/g, '').substring(1)}`} class="flex-1 sm:flex-none bg-amber-500 hover:bg-amber-600 text-slate-900 px-2 sm:px-8 py-3 sm:py-4 min-h-[48px] rounded-sm font-sans font-bold text-sm sm:text-base uppercase tracking-widest transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <i class="fas fa-phone-alt"></i> <span class="whitespace-nowrap">Call Now</span>
                </a>
                <a href={telegramLink} target="_blank" rel="noopener noreferrer" class="flex-1 sm:flex-none bg-[#0088cc] hover:bg-[#007ab8] text-white px-2 sm:px-8 py-3 sm:py-4 min-h-[48px] rounded-sm font-sans font-medium text-sm sm:text-base uppercase tracking-widest transition-colors flex items-center justify-center gap-2 shadow-lg">
                    <i class="fab fa-telegram-plane text-lg"></i> <span class="whitespace-nowrap">Consultation</span>
                </a>
            </div>
        </div>
      </header>

      <section class="py-12 bg-amber-500 relative z-20 shadow-xl">
        <div class="max-w-7xl mx-auto px-6">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center divide-x divide-amber-600/30">
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-5xl font-luxury-serif font-bold text-slate-950 mb-1 md:mb-2 tracking-wider">60+</span>
              <span class="text-slate-800 text-[10px] sm:text-xs md:text-sm font-sans font-medium uppercase tracking-widest">Years of Experience</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <div class="h-[28px] md:h-[48px] flex items-center mb-1 md:mb-2">
                  <i class="fas fa-gem text-2xl md:text-4xl text-slate-950 opacity-90"></i>
              </div>
              <span class="text-slate-800 text-[10px] sm:text-xs md:text-sm font-sans font-medium uppercase tracking-widest">Consistent Quality</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <div class="h-[28px] md:h-[48px] flex items-center mb-1 md:mb-2">
                  <i class="fas fa-concierge-bell text-2xl md:text-4xl text-slate-950 opacity-90"></i>
              </div>
              <span class="text-slate-800 text-[10px] sm:text-xs md:text-sm font-sans font-medium uppercase tracking-widest">High-Volume Capacity</span>
            </div>
            <div class="flex flex-col items-center justify-center">
              <span class="text-3xl md:text-5xl font-luxury-serif font-bold text-slate-950 mb-1 md:mb-2 tracking-wider">100%</span>
              <span class="text-slate-800 text-[10px] sm:text-xs md:text-sm font-sans font-medium uppercase tracking-widest">Food Safety Audited</span>
            </div>
          </div>
        </div>
      </section>

      <section id="service" class="py-16 md:py-24 bg-slate-900 relative overflow-hidden">
         <div class="max-w-7xl mx-auto px-6 relative z-10">
            <div class="text-center mb-12 md:mb-16"><h2 class="text-3xl md:text-4xl font-luxury-serif font-bold text-white tracking-wide">Operational Standards</h2></div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                 <div class="bg-slate-800/50 p-8 md:p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-6 md:mb-8"><i class="fas fa-gem text-xl md:text-2xl text-amber-500"></i></div>
                    <h3 class="text-xl md:text-2xl font-luxury-serif font-semibold text-white mb-3 md:mb-4 tracking-wide">Cold Chain Logistics</h3>
                    <p class="text-gray-400 text-sm md:text-base font-sans font-light leading-relaxed">We operate a strict cold chain from supplier to site. Ingredients are maintained below 4°C to prevent degradation and ensure absolute food safety before hitting the pan.</p>
                 </div>
                 <div class="bg-slate-800/50 p-8 md:p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-6 md:mb-8"><i class="fas fa-project-diagram text-xl md:text-2xl text-amber-500"></i></div>
                    <h3 class="text-xl md:text-2xl font-luxury-serif font-semibold text-white mb-3 md:mb-4 tracking-wide">High-Volume Execution</h3>
                    <p class="text-gray-400 text-sm md:text-base font-sans font-light leading-relaxed">We rely on strict prep schedules and batch-cooking mathematics. Whether serving 10 or 100 tables, our logistics ensure the food arrives hot and consistent across the room.</p>
                 </div>
                 <div class="bg-slate-800/50 p-8 md:p-10 rounded-lg border border-slate-700/50 hover:border-amber-500/30 transition-colors duration-500">
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-slate-900 rounded-full flex items-center justify-center border border-amber-500/30 mb-6 md:mb-8"><i class="fas fa-shield-alt text-xl md:text-2xl text-amber-500"></i></div>
                    <h3 class="text-xl md:text-2xl font-luxury-serif font-semibold text-white mb-3 md:mb-4 tracking-wide">Strict Food Safety</h3>
                    <p class="text-gray-400 text-sm md:text-base font-sans font-light leading-relaxed">We enforce physical separation between raw and cooked prep zones. Every hot dish is temperature-probed to cross the 75°C kill step before leaving the kitchen.</p>
                 </div>
            </div>
         </div>
      </section>

      <section id="portfolio" class="py-16 md:py-24 bg-white overflow-hidden">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-10 md:mb-16"><h2 class="text-3xl md:text-4xl font-luxury-serif font-bold text-slate-900 tracking-wide">Banquet Menu Signatures</h2></div>
          
          <div class="flex overflow-x-auto md:grid md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8 pb-6 -mx-6 px-6 md:mx-0 md:px-0 snap-x snap-mandatory scrollbar-hide">
            {menuItems.map((item) => (
                <div class="group relative overflow-hidden rounded-sm shadow-md bg-slate-50 flex-none w-[80%] sm:w-[50%] md:w-auto snap-center snap-always">
                    <div class="aspect-square overflow-hidden relative bg-slate-200">
                      <img src={item.image} alt={item.title} width="600" height="600" decoding="async" loading="lazy" class="w-full h-full object-cover transform group-hover:scale-105 transition duration-700"/>
                      <div class="absolute inset-0 bg-gradient-to-t from-slate-900/95 via-slate-900/30 to-transparent opacity-85 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    <div class="absolute inset-0 flex flex-col justify-end p-5 md:p-8 pointer-events-none">
                      <h3 class="text-lg md:text-xl font-luxury-serif font-semibold text-amber-400 mb-2 md:mb-3 md:translate-y-4 md:group-hover:translate-y-0 transition duration-500 tracking-wide">{item.title}</h3>
                      <p class="text-gray-200 text-xs md:text-sm font-sans font-light leading-relaxed md:opacity-0 md:group-hover:opacity-100 transform md:translate-y-4 md:group-hover:translate-y-0 transition-all duration-500 delay-100 line-clamp-3 md:line-clamp-none">{item.desc}</p>
                    </div>
                </div>
            ))}
          </div>
        </div>
      </section>

      <section id="insights" class="py-16 md:py-24 bg-slate-50 border-t border-slate-200">
        <div class="max-w-7xl mx-auto px-6">
           <div class="text-center mb-10 md:mb-16"><h2 class="text-3xl md:text-4xl font-luxury-serif font-bold text-slate-900 tracking-wide">Catering Operations Insights</h2></div>
           <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
              {blogPosts.map(post => (
                <div class="group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-500 border border-slate-100 flex flex-col">
                   <a href={post.link} class="block aspect-[16/9] overflow-hidden relative bg-slate-200">
                      <img src={post.image} alt={post.title} width="600" height="337" decoding="async" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition duration-700"/>
                   </a>
                   <div class="p-6 md:p-8 flex flex-col flex-grow">
                      <h3 class="text-lg md:text-xl font-luxury-serif font-semibold text-slate-900 mb-2 md:mb-3 group-hover:text-amber-600 transition-colors duration-300 leading-snug tracking-wide">{post.title}</h3>
                      <p class="text-slate-500 text-xs md:text-sm font-sans font-light mb-4 md:mb-6">{post.subTitle}</p>
                      <a href={post.link} class="mt-auto inline-flex items-center text-amber-600 text-xs md:text-sm font-sans font-medium uppercase tracking-widest hover:text-amber-700 transition-colors">Read Log <i class="fas fa-arrow-right ml-2"></i></a>
                   </div>
                </div>
              ))}
           </div>
        </div>
      </section>

      <section id="contact" class="relative py-20 md:py-32 bg-slate-950 border-t border-slate-800 overflow-hidden">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-[1px] bg-gradient-to-r from-transparent via-amber-500/30 to-transparent"></div>
          
          <div class="max-w-7xl mx-auto px-6 relative z-10">
              <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-16 lg:gap-8 items-center">
                  <div class="lg:col-span-5 text-left text-center lg:text-left">
                      <div class="inline-flex items-center gap-4 mb-6 md:mb-8">
                          <span class="w-8 md:w-12 h-[1px] bg-amber-500"></span>
                          <span class="text-amber-500 text-[10px] md:text-xs font-sans font-medium tracking-[0.2em] uppercase">Catering Consultation</span>
                          <span class="w-8 h-[1px] bg-amber-500 lg:hidden"></span>
                      </div>
                      <h2 class="text-3xl md:text-4xl lg:text-5xl font-luxury-serif font-bold text-white mb-6 md:mb-8 leading-tight tracking-wide">Start the Planning Process</h2>
                      <p class="text-slate-400 text-sm md:text-lg font-sans font-light leading-relaxed mb-8 md:mb-10 max-w-md mx-auto lg:mx-0">
                          A successful banquet starts with a hard assessment of your venue's infrastructure and logistical limits. Contact us to begin planning.
                      </p>
                  </div>

                  <div class="lg:col-span-7 lg:col-start-6">
                      <div class="bg-slate-900 border border-slate-800 p-6 md:p-12 rounded-sm shadow-2xl">
                          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4 mb-6 md:mb-10">
                              {phoneNumbers.map((contact) => (
                                  <a href={`tel:+855${contact.num.replace(/\s/g, '').substring(1)}`} class="group flex items-center p-4 md:p-6 rounded-sm bg-slate-950 border border-slate-800 hover:border-amber-500/50 transition-colors duration-300 min-h-[64px] md:min-h-[88px]">
                                      <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-900 flex items-center justify-center shrink-0 mr-4 group-hover:bg-amber-500/10 transition-colors">
                                        <i class={`fas ${contact.icon} text-amber-500 text-sm md:text-xl`}></i>
                                      </div>
                                      <div>
                                        <div class="text-white font-sans font-semibold text-base md:text-lg tracking-wide">{contact.num}</div>
                                        <div class="text-slate-500 text-[10px] md:text-xs font-sans uppercase tracking-[0.2em] mt-0.5 md:mt-1">{contact.type}</div>
                                      </div>
                                  </a>
                              ))}
                              
                              <div class="flex items-center gap-3 md:gap-4 p-4 md:p-6 rounded-sm bg-slate-950 border border-slate-800 min-h-[64px] md:min-h-[88px]">
                                  <a href={telegramLink} target="_blank" rel="noopener noreferrer" aria-label="Telegram" class="flex-1 h-10 md:h-12 rounded-sm bg-[#0088cc] hover:bg-[#007ab8] flex items-center justify-center text-white transition-colors duration-300">
                                      <i class="fab fa-telegram-plane text-base md:text-xl"></i>
                                  </a>
                                  <a href={facebookLink} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex-1 h-10 md:h-12 rounded-sm bg-[#1877F2] hover:bg-[#166FE5] flex items-center justify-center text-white transition-colors duration-300">
                                      <i class="fab fa-facebook-f text-base md:text-xl"></i>
                                  </a>
                              </div>
                          </div>
                          
                          <div class="pt-6 md:pt-8 border-t border-slate-800">
                              <div class="flex items-start gap-4 md:gap-6">
                                  <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-slate-950 border border-slate-800 flex items-center justify-center shrink-0">
                                      <i class="fas fa-map-marker-alt text-amber-500 text-sm md:text-base"></i>
                                  </div>
                                  <div>
                                      <h4 class="text-white font-sans font-medium text-xs md:text-sm tracking-[0.2em] uppercase mb-1.5 md:mb-2">Headquarters</h4>
                                      <p class="text-slate-400 text-xs md:text-sm font-sans font-light leading-relaxed">
                                          House 33, St. 257, Sangkat Tuek Laak 2<br class="hidden sm:block"/>Toul Kork, Phnom Penh
                                      </p>
                                  </div>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>
          </div>
      </section>
  </div>
</Layout>
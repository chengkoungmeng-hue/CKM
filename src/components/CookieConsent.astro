---
// src/components/CookieConsent.astro

export interface Props {
    lang?: "km" | "zh" | "en";
}

const { lang = "km" } = Astro.props;

// [戰略攔截] 語系正規化
const baseLang = lang.startsWith("km")
    ? "km"
    : lang.startsWith("zh")
      ? "zh"
      : "en";

const dict = {
    km: {
        title: "គោលការណ៍ឯកជនភាព និងខូគី",
        description: "គេហទំព័រនេះប្រើប្រាស់ខូគីដើម្បីបង្កើនបទពិសោធន៍របស់អ្នក និងវិភាគចរាចរណ៍គេហទំព័រ។ ដោយចុច 'យល់ព្រម' អ្នកយល់ព្រមឱ្យយើងប្រើប្រាស់ខូគី។",
        accept: "យល់ព្រម",
        decline: "បដិសេធ",
        policy: "គោលការណ៍ឯកជនភាព"
    },
    zh: {
        title: "隐私与 Cookie 政策",
        description: "本网站使用 Cookie 与相关技术来优化您的浏览体验，并进行网站流量分析。点击「授权存取」即表示您同意我们使用 Cookie。",
        accept: "授权存取",
        decline: "拒绝",
        policy: "隐私政策"
    },
    en: {
        title: "Privacy & Cookie Policy",
        description: "This website uses cookies to enhance your browsing experience and analyze site traffic. By clicking 'Accept', you consent to our use of cookies.",
        accept: "Accept",
        decline: "Decline",
        policy: "Privacy Policy"
    }
};

const t = dict[baseLang];

// Dynamically construct privacy route based on existing logic
const privacyRoute = baseLang === "km" ? "/privacy" : `/${baseLang}/privacy`;
---

<div 
  id="cookie-consent-banner" 
  class="fixed bottom-0 left-0 right-0 z-[100] transform translate-y-[120%] opacity-0 transition-all duration-700 ease-[cubic-bezier(0.19,1,0.22,1)] p-4 md:p-6 flex justify-center pointer-events-none pb-[calc(1rem+env(safe-area-inset-bottom))]"
>
  <!-- CKM Luxury Aesthetic Panel -->
  <div class="bg-slate-950/95 backdrop-blur-md border border-amber-500/30 shadow-[0_0_30px_rgba(245,158,11,0.15)] max-w-4xl w-full pointer-events-auto flex flex-col md:flex-row gap-6 p-6 rounded-sm relative overflow-hidden">
    
    <!-- Shimmer Top Line -->
    <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-amber-500/50 to-transparent"></div>

    <div class="flex-1 flex flex-col justify-center text-slate-300">
      <div class="flex items-center gap-2.5 mb-2.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <h3 class={`text-amber-500 font-bold tracking-wide ${baseLang === 'km' ? 'font-serif' : 'font-sans text-sm md:text-base uppercase'}`}>{t.title}</h3>
      </div>
      <p class={`leading-relaxed opacity-90 ${baseLang === 'km' ? 'font-sans text-sm md:text-base' : 'font-sans text-xs md:text-sm'}`}>
        {t.description} 
        <a href={privacyRoute} class="text-amber-400 hover:text-amber-300 underline underline-offset-4 decoration-amber-500/30 hover:decoration-amber-400 ml-1 transition-colors">{t.policy}</a>
      </p>
    </div>

    <div class="flex flex-row md:flex-col lg:flex-row gap-3 shrink-0 items-center justify-center pt-2 md:pt-0 border-t md:border-t-0 border-slate-800 md:pl-6 md:border-l">
      <button 
        id="decline-cookies" 
        class="flex-1 md:flex-none border border-slate-700 bg-transparent text-slate-400 hover:border-amber-500/50 hover:text-amber-400 px-6 py-2.5 text-xs lg:text-sm font-sans tracking-wide rounded-sm transition-all duration-300"
      >
        {t.decline}
      </button>
      <button 
        id="accept-cookies" 
        class="flex-1 md:flex-none bg-amber-500 hover:bg-amber-400 text-slate-950 px-8 py-2.5 text-xs lg:text-sm font-sans font-bold tracking-wide rounded-sm transition-all duration-300 shadow-[0_0_15px_rgba(245,158,11,0.2)] hover:shadow-[0_0_20px_rgba(245,158,11,0.4)] whitespace-nowrap"
      >
        {t.accept}
      </button>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const consentGiven = localStorage.getItem('cookie-consent');
    const consentBanner = document.getElementById('cookie-consent-banner');
    
    if (!consentGiven && consentBanner) {
      setTimeout(() => {
        consentBanner.classList.remove('translate-y-[120%]', 'opacity-0');
        consentBanner.classList.add('translate-y-0', 'opacity-100');
      }, 600);
    }
    
    const acceptBtn = document.getElementById('accept-cookies');
    if (acceptBtn) {
      acceptBtn.addEventListener('click', () => {
        localStorage.setItem('cookie-consent', 'accepted');
        if (typeof zaraz !== 'undefined') {
          zaraz.consent.setAll(true);
        }
        hideBanner();
      });
    }
    
    const declineBtn = document.getElementById('decline-cookies');
    if (declineBtn) {
      declineBtn.addEventListener('click', () => {
        localStorage.setItem('cookie-consent', 'declined');
        if (typeof zaraz !== 'undefined') {
          zaraz.consent.setAll(false);
        }
        hideBanner();
      });
    }
    
    function hideBanner() {
      if (consentBanner) {
        consentBanner.classList.remove('translate-y-0', 'opacity-100');
        consentBanner.classList.add('translate-y-[120%]', 'opacity-0');
        setTimeout(() => {
          consentBanner.style.display = 'none';
        }, 700);
      }
    }
  });
</script>

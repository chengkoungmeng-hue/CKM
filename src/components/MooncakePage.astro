---
import { Image } from "astro:assets";
import imgLogo29 from '../assets/images/tanghuot/nom-lok-khae-logo-image_29.webp';
import imgLogoTanghout from '../assets/images/tanghuot/logo-tanghout.webp';
import imgHeroStone from '../assets/images/tanghuot/hero-abstract-angkor-stone.webp';
import imgProducts from '../assets/images/tanghuot/nom-products-tang-huot.webp';
import imgSlice from '../assets/images/tanghuot/nom-lok-khae-slice-image_2.webp';
import imgCholChnam from '../assets/images/tanghuot/nom-chol-chnam-image_20_generated.webp';
import imgSteamer from '../assets/images/tanghuot/hero-steamer-tradition.webp';
import Layout from "../layouts/Layout.astro";

import '@fontsource/battambang/300.css';
import '@fontsource/battambang/400.css';
import '@fontsource/battambang/700.css';
import '@fontsource/hanuman/300.css';
import '@fontsource/hanuman/400.css';
import '@fontsource/hanuman/700.css';
import '@fontsource/hanuman/900.css';


interface Props {
  lang?: "km" | "en" | "zh";
}

const { lang = "km" } = Astro.props;

// Multi-language dictionary
const t = (() => {
  switch (lang) {
    case "en":
      return {
        seoTitle: "Tang Huot Bakery | Traditional Pastries & Mooncakes Wholesale",
        seoDesc: "Tang Huot Bakery supplies egg yolk pies, mooncakes, and Fa Gao. We focus on reliable production, hygiene, and consistent quality.",
        h1: "Tang Huot Bakery",
        heroSub: "Traditional Pastries Wholesale",
        heroHighlight: "Reliable High-Volume Supply",
        heroDesc: "Tang Huot Bakery supplies egg yolk pies, mooncakes, and Fa Gao for wholesale and festive seasons. Operating from our new facility, we focus on maintaining hygiene and a consistent, pleasant taste for all our partners.",
        preorderTitle: "Wholesale & Orders",
        sigTag: "Classic Pastry",
        sigTitle: "Tang Huot Egg Yolk Pie: A Traditional Taste",
        sigDesc: "The egg yolk pie is a pastry we make with care. Even during large production runs, we carefully monitor the baking process to ensure the crust remains flaky and the center stays soft and flavorful.",
        mcTitle: "Festive Mooncakes: Baked with Care",
        mcDesc: "Making mooncakes in large quantities requires careful attention. We use large ovens and monitor temperatures closely to ensure an even bake. We strive to keep the fillings moist and tender for the festive season.",
        fagaoTitle: "Fa Gao: Prepared for the Lunar New Year",
        fagaoDesc1: "During the Lunar New Year, we are fully prepared to supply our wholesale partners with a steady quantity of Fa Gao.",
        fagaoDesc2: "A good Fa Gao requires the right batter and careful steaming. We watch the heat closely to ensure each cake blooms properly, making them a suitable offering for the new year.",
        contactTitle: "Contact Us",
        facilityTag: "Modern Production Facility",
        address: "House 454, Trapeang Thleung 1 Village, Sangkat Chom Chao, Khan Pou Senchey, Phnom Penh",
      };
    case "zh":
      return {
        seoTitle: "陈发饼家 | 传统糕饼与节庆月饼批发",
        seoDesc: "陈发饼家专营蛋黄酥、月饼与发糕批发。我们在新厂房中稳定生产，注重卫生与品质，为您提供可靠的糕饼供应。",
        h1: "陈发饼家",
        heroSub: "传统糕饼与节庆月饼",
        heroHighlight: "稳定的大宗批发供应",
        heroDesc: "陈发饼家主要供应蛋黄酥、中秋月饼与发糕。我们在新的厂房中生产，注重环境卫生与制程稳定，希望能为您的节庆或生意提供可靠、实在的传统糕点。",
        preorderTitle: "批发与订购咨询",
        sigTag: "经典糕点",
        sigTitle: "陈发蛋黄酥：实在的传统味道",
        sigDesc: "蛋黄酥是我们常年制作的糕点。每一颗的烘焙我们都按部就班，努力让外皮保持酥脆，内馅保持顺口。即使是面对大宗订单，我们也会尽力维持一贯的品质标准。",
        mcTitle: "节庆月饼：注重火候，用心烘焙",
        mcDesc: "制作大量月饼需要耐心照顾。我们使用大型烤炉并谨慎控制温度，努力让月饼受热均匀、色泽实在。内馅方面也力求温润顺口，希望在佳节期间为大家提供安心、实在的月饼。",
        fagaoTitle: "传统发糕：年节祈福的心意",
        fagaoDesc1: "在农历新年期间，我们有足够的设备与人力，能为批发伙伴提供数量稳定的发糕。",
        fagaoDesc2: "发糕的制作需要注意面糊比例与蒸煮的火候。我们小心看顾蒸汽的强度，希望能让每一颗发糕都顺利绽放，为您增添新年的福气与好兆头。",
        contactTitle: "联系我们",
        facilityTag: "现代厂房生产",
        address: "金边市 菩森芷区 宗周分区 德邦特楞1村 454号",
      };
    case "km":
    default:
      return {
        seoTitle: "ហាងនំ តាំង ហួត | បោះដុំនំប្រពៃណី និងនំព្រះខែ",
        seoDesc: "ហាងនំ តាំង ហួត ទទួលបោះដុំនំពងទា នំព្រះខែ និងនំហ្វាកាវ។ យើងផលិតដោយយកចិត្តទុកដាក់លើអនាម័យ និងរក្សាគុណភាពជូនអតិថិជន។",
        h1: "ហាងនំ តាំង ហួត",
        heroSub: "បោះដុំនំពងទា និងនំប្រពៃណី",
        heroHighlight: "ផ្គត់ផ្គង់នំក្នុងបរិមាណច្រើន",
        heroDesc: "ហាងនំ តាំង ហួត ផ្គត់ផ្គង់នំពងទា នំព្រះខែ និងនំហ្វាកាវ សម្រាប់លក់បន្ត និងរដូវកាលបុណ្យទាន។ យើងខិតខំផលិតនំនៅក្នុងរោងនំថ្មី ដោយរក្សាអនាម័យ និងរសជាតិឱ្យបានល្អ ដើម្បីបំពេញតម្រូវការអតិថិជន។",
        preorderTitle: "ទំនាក់ទំនងបោះដុំ និងលក់រាយ",
        sigTag: "នំប្រចាំហាង",
        sigTitle: "នំពងទា តាំង ហួត៖ រសជាតិដើម",
        sigDesc: "នំពងទា ជានំដែលយើងតែងតែធ្វើជាប្រចាំ។ ទោះបីជាត្រូវផលិតច្រើន យើងនៅតែយកចិត្តទុកដាក់លើការដុតនំ ដើម្បីឱ្យសំបកនំស្អាត ហើយសាច់ខាងក្នុងនៅតែទន់ និងងាយស្រួលញ៉ាំ។",
        mcTitle: "នំព្រះខែ៖ យកចិត្តទុកដាក់លើការដុត",
        mcDesc: "ការធ្វើនំព្រះខែក្នុងបរិមាណច្រើន ទាមទារការពិនិត្យមើលឱ្យបានដិតដល់។ យើងប្រើប្រាស់ឡដុតធំៗ និងគ្រប់គ្រងកម្តៅដោយប្រុងប្រយ័ត្ន ដើម្បីឱ្យនំឆ្អិនល្អ មានពណ៌ស្អាត និងសាច់ខាងក្នុងទន់ល្មម មិនស្ងួត។",
        fagaoTitle: "នំហ្វាកាវ សម្រាប់ចូលឆ្នាំចិន",
        fagaoDesc1: "នៅពេលចូលឆ្នាំចិន យើងរៀបចំខ្លួនរួចរាល់ ដើម្បីផ្គត់ផ្គង់នំហ្វាកាវជូនអតិថិជនបោះដុំឱ្យបានគ្រប់គ្រាន់។",
        fagaoDesc2: "ការធ្វើនំហ្វាកាវទាមទារការលាយម្សៅ និងការមើលភ្លើងចំហុយឱ្យបានត្រឹមត្រូវ។ យើងតែងតែប្រុងប្រយ័ត្ន ដើម្បីឱ្យនំរាល់ដុំរីកបានស្អាត សម្រាប់ជាការជូនពរ និងសែនព្រេនក្នុងឆ្នាំថ្មី។",
        contactTitle: "ទំនាក់ទំនង",
        facilityTag: "ផលិតក្នុងរោងនំថ្មី",
        address: "ផ្ទះលេខ៤៥៤ ផ្លូវលំភូមិត្រពាំងថ្លឹង១ សង្កាត់ចោមចៅ ខណ្ឌពោធិ៍សែនជ័យ រាជធានីភ្នំពេញ",
      };
  }
})();
---

<Layout title={t.seoTitle} description={t.seoDesc} lang={lang}>
  <Fragment slot="head">
    <link rel="icon" type="image/x-icon" href="/thicon.ico" />
    <!-- LCP preload removed in favor of Astro Image handling -->

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": ["WholesaleStore", "Bakery"],
        "name": t.h1,
        "image": `https://www.ckmkh.com${imgLogo29.src}`,
        "description": t.seoDesc,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": t.address,
          "addressLocality": "Phnom Penh",
          "addressRegion": "Phnom Penh",
          "addressCountry": "KH"
        },
        "telephone": "+85512677710",
        "url": `https://www.ckmkh.com${lang === 'km' ? '/tanghuot/' : `/${lang}/tanghuot/`}`,
        "priceRange": "$$",
        "sameAs": [
          "https://www.facebook.com/people/%E1%9E%A0%E1%9E%B6%E1%9E%84%E1%9E%93%E1%9F%86-%E1%9E%8F%E1%9E%B6%E1%9F%86%E1%9E%84-%E1%9E%A0%E1%9E%BD%E1%9E%8F/100063625998376/"
        ]
      })}
    />



    <style is:global>
      :root {
        --kh-red: #e31d2b;
      }
      .bg-kh-red {
        background-color: var(--kh-red);
      }
      .text-kh-red {
        color: var(--kh-red);
      }
      .border-kh-red {
        border-color: var(--kh-red);
      }
      .font-heading {
        font-family: "Hanuman", serif;
      }
      .font-body {
        font-family: "Battambang", sans-serif;
      }
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </Fragment>

  <div
    class="bg-slate-950 text-slate-200 font-body antialiased selection:bg-kh-red selection:text-white"
  >
    <header
      class="relative min-h-[calc(100vh-80px)] flex items-center justify-center overflow-hidden border-b border-white/5"
    >
      <Image
        src={imgLogo29}
        alt="នំលោកខែប្រណីត"
        format="avif"
        quality={50}
        width={1920}
        height={1080}
        widths={[400, 800, 1200, 1920]}
        sizes="100vw"
        class="absolute inset-0 w-full h-full object-cover object-center"
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
      <div
        class="absolute inset-0 bg-gradient-radial from-transparent via-black/50 to-slate-950 opacity-95"
      >
      </div>

      <div
        class="relative z-10 text-center px-6 max-w-5xl mx-auto pt-16 pb-24 space-y-8"
      >
        <div class="flex justify-center mb-6">
          <Image
            src={imgLogoTanghout}
            alt="Tang Huot Logo"
            format="avif"
            width={250}
            height={250}
            widths={[128, 250, 400]}
            sizes="(max-width: 768px) 128px, 250px"
            loading="eager"
            decoding="async"
            class="h-28 w-auto md:h-40 object-contain drop-shadow-[0_0_15px_rgba(0,0,0,0.8)]"
          />
        </div>

        <h1
          class="text-6xl md:text-8xl font-black text-white leading-tight tracking-wide font-heading drop-shadow-2xl"
        >
          {t.h1}
        </h1>
        <h2
          class="text-2xl md:text-4xl font-bold text-white/90 tracking-widest font-heading drop-shadow-lg"
        >
          {t.heroSub}
          <br class="md:hidden" /><span class="text-kh-red drop-shadow-md"
            >{t.heroHighlight}</span
          >
        </h2>
        <p
          class="text-lg md:text-2xl text-gray-300 mb-16 max-w-3xl mx-auto font-light leading-loose tracking-wide drop-shadow-md"
        >
          {t.heroDesc}
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center pt-8">
          <a
            href="#contact"
            class="bg-kh-red hover:bg-red-700 text-white px-14 py-5 rounded-sm font-bold text-lg transition flex items-center justify-center gap-3 shadow-[0_0_20px_rgba(227,29,43,0.5)] tracking-wider"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
            {t.preorderTitle}
          </a>
        </div>
      </div>
    </header>

    <section
      id="abundance"
      class="py-16 md:py-24 border-b border-white/5 relative overflow-hidden bg-slate-950"
    >
      <div class="absolute inset-0 z-0">
        <Image
          src={imgHeroStone}
          alt="Texture"
          format="avif"
          width={1920}
          height={1080}
          widths={[400, 800, 1200, 1920]}
          sizes="100vw"
          class="w-full h-full object-cover opacity-70 mix-blend-luminosity"
          loading="lazy"
          decoding="async"
        />
        <div
          class="absolute inset-0 bg-gradient-to-b from-slate-950 via-transparent to-slate-950 opacity-40"
        >
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div
          class="grid grid-cols-1 md:grid-cols-12 gap-10 lg:gap-16 items-center"
        >
          <div
            class="md:col-span-5 space-y-6 md:space-y-8 text-center md:text-left"
          >
            <div
              class="inline-flex items-center gap-3 px-4 py-1.5 bg-amber-500/10 border border-amber-500/30 rounded-full text-amber-500 font-sans font-bold text-xs uppercase tracking-widest"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="8" r="6"></circle><path
                  d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path></svg
              >
              <span>{t.sigTag}</span>
            </div>
            <h3
              class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight font-heading drop-shadow-lg"
            >
              {t.sigTitle}
            </h3>
            <div
              class="w-20 h-1 bg-kh-red mx-auto md:mx-0 shadow-[0_0_10px_rgba(227,29,43,0.5)]"
            >
            </div>
            <p
              class="text-xl md:text-2xl text-gray-300 font-light leading-loose tracking-wide drop-shadow-sm"
            >
              {t.sigDesc}
            </p>
          </div>
          <div class="md:col-span-7">
            <div
              class="relative rounded-sm overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)] border border-white/10 group"
            >
              <Image
                src={imgProducts}
                alt="Products"
                format="avif"
                width={1200}
                height={800}
                widths={[400, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 50vw"
                class="w-full h-auto object-cover transform group-hover:scale-105 transition duration-1000"
                loading="lazy"
                decoding="async"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"
              >
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="mooncakes" class="bg-slate-900 border-b border-white/5">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        <div class="relative h-[40vh] sm:h-[50vh] lg:h-auto overflow-hidden">
          <Image
            src={imgSlice}
            alt="Mooncake Slice"
            format="avif"
            width={1000}
            height={1000}
            widths={[400, 800, 1000]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            class="absolute inset-0 w-full h-full object-cover object-center transform hover:scale-105 transition duration-1000"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div
          class="flex flex-col justify-center p-12 md:p-20 lg:p-24 space-y-8"
        >
          <div
            class="w-14 h-14 bg-slate-950 border border-white/10 rounded-full flex items-center justify-center text-amber-500 shadow-lg"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"
              ></path></svg
            >
          </div>
          <h3
            class="text-4xl md:text-5xl font-black text-white leading-tight font-heading drop-shadow-lg"
          >
            {t.mcTitle}
          </h3>
          <div class="w-20 h-1 bg-kh-red shadow-[0_0_10px_rgba(227,29,43,0.5)]">
          </div>
          <p
            class="text-xl md:text-2xl text-gray-300 font-light leading-loose tracking-wide drop-shadow-sm"
          >
            {t.mcDesc}
          </p>
        </div>
      </div>
    </section>

    <section
      id="fagao"
      class="bg-white border-b border-slate-200 selection:bg-slate-200 selection:text-slate-900"
    >
      <div class="grid grid-cols-1 lg:grid-cols-2">
        <div
          class="order-2 lg:order-1 flex flex-col justify-center p-12 md:p-20 lg:p-24 space-y-8 bg-slate-50"
        >
          <div

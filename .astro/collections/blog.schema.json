{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 200
    },
    "seoTitle": {
      "type": "string",
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 400
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "coverImage": {
      "type": "string"
    },
    "targetGeo": {
      "default": "Phnom Penh, Cambodia",
      "type": "string"
    },
    "authoritySignals": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "schemaType": {
      "default": "Article",
      "type": "string",
      "enum": [
        "Article",
        "FAQPage",
        "HowTo"
      ]
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "seoTitle",
    "description",
    "coverImage",
    "authoritySignals"
  ]
}